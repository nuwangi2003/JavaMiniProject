<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.attendance.AttendanceManagementController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #0f1b35;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="🛠" style="-fx-font-size: 24px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="Attendance Module" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Technical Officer Panel" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8">
                <padding><Insets left="16" right="20"/></padding>
                <Label text="Update / Delete Attendance" style="-fx-text-fill: #a0c4ff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-background-color: #0f1b35;">
            <padding><Insets top="30" bottom="30" left="38" right="38"/></padding>

            <VBox spacing="4">
                <Label text="Attendance Management"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Update or delete an existing attendance record."
                       style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="18"
                  style="-fx-background-color: #162040; -fx-background-radius: 14;
                         -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

                <VBox spacing="7">
                    <Label text="Attendance ID" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="attendanceIdField" promptText="e.g. 5"
                               style="-fx-background-color: #0f1b35; -fx-text-fill: white; -fx-prompt-text-fill: #3a5a8a;
                                      -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;"/>
                </VBox>

                <HBox spacing="20">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="New Status (Present / Absent)" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="updateStatusField" promptText="Absent"
                                   style="-fx-background-color: #0f1b35; -fx-text-fill: white; -fx-prompt-text-fill: #3a5a8a;
                                          -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;"/>
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="New Hours Attended" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <TextField fx:id="updateHoursField" promptText="0.0"
                                   style="-fx-background-color: #0f1b35; -fx-text-fill: white; -fx-prompt-text-fill: #3a5a8a;
                                          -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;"/>
                    </VBox>
                </HBox>

                <Label fx:id="resultLabel" textFill="WHITE" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Back Dashboard" onAction="#backToDashboard"
                            style="-fx-background-color: #1e2d50; -fx-text-fill: #a0b8e0; -fx-background-radius: 8;
                                   -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>
                    <Button text="Go Mark Attendance" onAction="#openMarkAttendance"
                            style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button text="Delete Attendance" onAction="#deleteAttendance"
                            style="-fx-background-color: linear-gradient(to right, #7b2d00, #c0622a); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    <Button text="Update Attendance" onAction="#updateAttendance"
                            style="-fx-background-color: linear-gradient(to right, #0a4a6e, #1565c0); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
