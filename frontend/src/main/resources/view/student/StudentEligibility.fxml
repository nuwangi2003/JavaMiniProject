<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.student.StudentEligibilityController"
            prefWidth="1200"
            prefHeight="750"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>

            <VBox spacing="3">
                <Label text="✅ My Exam Eligibility"
                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="Attendance + CA eligibility with approved medical consideration"
                       style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 12px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back"
                    onAction="#goBack"
                    style="-fx-background-color: white;
                           -fx-text-fill: #3f7fc2;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="18">
                <padding>
                    <Insets top="28" right="34" bottom="28" left="34"/>
                </padding>

                <HBox spacing="16">
                    <VBox prefWidth="240"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #d7e7f8; -fx-border-radius: 16;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="Eligible Subjects"
                               style="-fx-text-fill: #35a053; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="eligibleCountLabel" text="0"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 36px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox prefWidth="240"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #d7e7f8; -fx-border-radius: 16;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="Not Eligible"
                               style="-fx-text-fill: #e85d5d; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="notEligibleCountLabel" text="0"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 36px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox prefWidth="240"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #d7e7f8; -fx-border-radius: 16;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="Total Subjects"
                               style="-fx-text-fill: #468ed0; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalSubjectsLabel" text="0"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 36px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <Label text="Subject Eligibility Details"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 17px; -fx-font-weight: bold;"/>

                    <Separator/>

                    <VBox fx:id="eligibilityContainer" spacing="10"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>