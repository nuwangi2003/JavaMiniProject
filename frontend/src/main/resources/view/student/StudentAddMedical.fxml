<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.controller.student.StudentAddMedicalController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);                      -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" prefHeight="72" prefWidth="438.0" spacing="12">
                <padding>
                    <Insets left="24" right="24" />
                </padding>

                <StackPane prefHeight="62.0" prefWidth="62.0" style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label prefHeight="120.0" prefWidth="100.0" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="   🎓" />
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="FoT Portal" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;" text="Student Medicals" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets left="16" right="16" />
                </padding>

                <Button onAction="#backToDashboard" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Dashboard" />

                <Button onAction="#openViewMedical" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="View Medicals" />

                <Button style="-fx-background-color: rgba(255,255,255,0.22);                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-font-weight: bold;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: default;" text="Add Medical" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" prefHeight="72.0" prefWidth="242.0" spacing="10">
                <padding>
                    <Insets left="10" right="20" />
                </padding>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="studentNameLabel" prefHeight="16.0" prefWidth="138.0" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Student" />
                    <Label fx:id="headerRegNoLabel" style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;" text="Reg No" />
                </VBox>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="22">
            <padding>
                <Insets bottom="28" left="40" right="40" top="28" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="18" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-border-color: #d7e7f8;                          -fx-border-radius: 16;                          -fx-border-width: 1;">
                <padding>
                    <Insets bottom="20" left="24" right="24" top="20" />
                </padding>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 24px; -fx-font-weight: bold;" text="Upload Medical" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="todayLabel" style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px; -fx-font-weight: bold;" text="" />
            </HBox>

            <VBox spacing="18" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-border-color: #d7e7f8;                          -fx-border-radius: 16;                          -fx-border-width: 1;                          -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.12), 14, 0, 0, 4);">
                <padding>
                    <Insets bottom="24" left="28" right="28" top="24" />
                </padding>

                <HBox spacing="22">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;" text="Your Registration Number" />
                        <Label fx:id="regNoLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;" text="Exam Type" />
                        <ComboBox fx:id="examTypeCombo" maxWidth="Infinity" prefHeight="42" style="-fx-background-color: white;                                          -fx-border-color: #d7e7f8;                                          -fx-border-radius: 10;                                          -fx-background-radius: 10;" />
                    </VBox>
                </HBox>

                <HBox spacing="22">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;" text="Course" />
                        <ComboBox fx:id="courseCombo" maxWidth="Infinity" prefHeight="42" promptText="Select your course" style="-fx-background-color: white;                                          -fx-border-color: #d7e7f8;                                          -fx-border-radius: 10;                                          -fx-background-radius: 10;" />
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;" text="Submitted Date" />
                        <DatePicker fx:id="submittedDatePicker" maxWidth="Infinity" prefHeight="42" style="-fx-background-color: white;                                            -fx-border-color: #d7e7f8;                                            -fx-border-radius: 10;                                            -fx-background-radius: 10;" />
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;" text="Medical File" />
                    <HBox spacing="10">
                        <TextField fx:id="medicalFileField" editable="false" promptText="Choose your PDF or image file" style="-fx-background-color: white;                                      -fx-text-fill: #1a3a52;                                      -fx-prompt-text-fill: #a8b8ca;                                      -fx-border-color: #d7e7f8;                                      -fx-border-radius: 10;                                      -fx-background-radius: 10;" HBox.hgrow="ALWAYS" />
                        <Button onAction="#chooseMedicalFile" style="-fx-background-color: #eef4fb;                                        -fx-text-fill: #3f7fc2;                                        -fx-font-size: 12px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 8;                                        -fx-cursor: hand;" text="Browse File" />
                    </HBox>
                    <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="The selected local file path will be stored and can be opened later from View Medicals." />
                </VBox>

                <Separator style="-fx-background-color: #e7eef7;" />

                <Label fx:id="statusLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" text="" />

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button onAction="#clearForm" style="-fx-background-color: #eef4fb;                                    -fx-text-fill: #3f7fc2;                                    -fx-font-size: 12px;                                    -fx-font-weight: bold;                                    -fx-background-radius: 8;                                    -fx-cursor: hand;" text="Clear" />

                    <Button onAction="#submitMedical" style="-fx-background-color: linear-gradient(to right, #4cba52, #43a649);                                    -fx-text-fill: white;                                    -fx-font-size: 12px;                                    -fx-font-weight: bold;                                    -fx-background-radius: 8;                                    -fx-cursor: hand;" text="Submit Medical" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
