<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.student.StudentViewMedicalController"
            prefWidth="1180.0" prefHeight="720.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="72">
                <padding>
                    <Insets left="24" right="24"/>
                </padding>

                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label text="M" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Student Medicals"
                           style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="6" alignment="CENTER">
                <padding>
                    <Insets left="16" right="16"/>
                </padding>

                <Button text="Dashboard" onAction="#backToDashboard"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;"/>

                <Button text="View Medicals"
                        style="-fx-background-color: rgba(255,255,255,0.22);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: default;"/>

                <Button text="Add Medical" onAction="#openAddMedical"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="10" right="20"/>
                </padding>

                <StackPane prefWidth="36" prefHeight="36"
                           style="-fx-background-color: white; -fx-background-radius: 18;">
                    <Label text="S"
                           style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="studentNameLabel" text="Student"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label fx:id="regNoLabel" text="Reg No"
                           style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;"/>
                </VBox>

                <Button text="Refresh" onAction="#refreshRecords"
                        style="-fx-background-color: rgba(255,255,255,0.18);
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.22);
                               -fx-border-radius: 8;
                               -fx-border-width: 1;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="22">
            <padding>
                <Insets top="28" bottom="28" left="34" right="34"/>
            </padding>

            <HBox spacing="18" alignment="CENTER_LEFT"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 16;
                         -fx-border-width: 1;">
                <padding>
                    <Insets top="20" bottom="20" left="24" right="24"/>
                </padding>

                <VBox spacing="5">
                    <Label text="Uploaded Medical History"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label fx:id="summaryLabel" text="0 records"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="todayLabel" text=""
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </HBox>

            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 16;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.12), 14, 0, 0, 4);">
                <padding>
                    <Insets top="22" bottom="22" left="24" right="24"/>
                </padding>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Medical Records Table"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Your uploaded records"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                </HBox>

                <Label fx:id="statusLabel" text=""
                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                <TableView fx:id="medicalTable" prefHeight="500"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d7e7f8;">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID"/>
                        <TableColumn fx:id="courseColumn" prefWidth="150.0" text="Course"/>
                        <TableColumn fx:id="examTypeColumn" prefWidth="120.0" text="Exam Type"/>
                        <TableColumn fx:id="submittedDateColumn" prefWidth="140.0" text="Submitted Date"/>
                        <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Status"/>
                        <TableColumn fx:id="copyColumn" prefWidth="490.0" text="Medical Copy / Note"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
