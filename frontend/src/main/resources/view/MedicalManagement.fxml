<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend.controller.medical.MedicalManagementController"
      spacing="10" style="-fx-background-color: #0f1b35;">
    <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label text="Medical Management" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Back Dashboard" onAction="#backToDashboard"
                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-background-radius: 8;"/>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Batch" style="-fx-text-fill: #a0c4ff;"/>
        <TextField fx:id="batchField" promptText="e.g. 2023" prefWidth="120"/>
        <Label text="Status" style="-fx-text-fill: #a0c4ff;"/>
        <ComboBox fx:id="statusFilterCombo" prefWidth="120"/>
        <Button text="Load Records" onAction="#loadBatchRecords"
                style="-fx-background-color: #1e3c72; -fx-text-fill: white;"/>
    </HBox>

    <TextArea fx:id="recordsTextArea" prefHeight="420" wrapText="true"/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Medical ID" style="-fx-text-fill: #a0c4ff;"/>
        <TextField fx:id="medicalIdField" prefWidth="100" promptText="id"/>
        <Button text="Approve" onAction="#approveSelected"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="Reject" onAction="#rejectSelected"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <Label fx:id="statusLabel" textFill="white"/>
</VBox>
