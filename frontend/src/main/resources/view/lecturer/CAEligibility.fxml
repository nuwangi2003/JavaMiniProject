<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.CAEligibilityController"
            prefWidth="1150"
            prefHeight="720"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.28), 16, 0, 0, 4);">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="74">
                <padding>
                    <Insets left="26" right="26"/>
                </padding>

                <StackPane prefWidth="46" prefHeight="46"
                           style="-fx-background-color: white;
                                  -fx-background-radius: 23;
                                  -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 8, 0, 0, 2);">
                    <Label text="🎓" style="-fx-font-size: 18px;"/>
                </StackPane>

                <VBox spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="CA Eligibility Management"
                           style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets right="24"/>
                </padding>

                <Label text="✅ CA Eligibility"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                              -fx-text-fill: white;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;
                              -fx-background-radius: 20;
                              -fx-padding: 8 16;"/>

                <Button text="← Dashboard"
                        onAction="#goBack"
                        style="-fx-background-color: white;
                               -fx-text-fill: #3f7fc2;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="22">
            <padding>
                <Insets top="28" right="34" bottom="28" left="34"/>
            </padding>

            <HBox alignment="CENTER_LEFT"
                  spacing="18"
                  style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff);
                         -fx-background-radius: 18;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 18;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">

                <padding>
                    <Insets top="22" right="24" bottom="22" left="24"/>
                </padding>

                <StackPane prefWidth="58" prefHeight="58"
                           style="-fx-background-color: linear-gradient(to bottom right, #5b9fd9, #7cb7ea);
                                  -fx-background-radius: 29;">
                    <Label text="📊" style="-fx-font-size: 22px;"/>
                </StackPane>

                <VBox spacing="5">
                    <Label text="Check CA Eligibility"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Best 2 quizzes + all other CA components. Below 50% means not eligible for final exam."
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <VBox spacing="0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 16;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.12), 14, 0, 0, 5);">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 16 16 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">

                    <padding>
                        <Insets top="18" right="24" bottom="18" left="24"/>
                    </padding>

                    <Label text="🔍" style="-fx-font-size: 18px;"/>

                    <VBox spacing="1">
                        <Label text="Filter Options"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Select assigned course and search by reg no, name, course, or eligibility status."
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="20" right="24" bottom="20" left="24"/>
                    </padding>

                    <ComboBox fx:id="courseBox"
                              promptText="Select course"
                              prefWidth="340"
                              onAction="#loadCAEligibility"
                              style="-fx-background-color: white;
                                     -fx-border-color: #d4e4f7;
                                     -fx-border-radius: 8;
                                     -fx-background-radius: 8;
                                     -fx-padding: 4;"/>

                    <TextField fx:id="searchField"
                               promptText="Search regNo, name, course, status..."
                               onKeyReleased="#filterTable"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white;
                                      -fx-border-color: #d4e4f7;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 10;"/>

                    <Button text="Clear"
                            onAction="#clearSearch"
                            prefWidth="100"
                            style="-fx-background-color: #e8eef5;
                                   -fx-text-fill: #5b9fd9;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-border-color: #d4e4f7;
                                   -fx-border-radius: 8;
                                   -fx-cursor: hand;"/>

                    <Button text="Refresh"
                            onAction="#loadCAEligibility"
                            prefWidth="110"
                            style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <VBox spacing="0"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 16;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.12), 14, 0, 0, 5);">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 16 16 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">

                    <padding>
                        <Insets top="18" right="24" bottom="18" left="24"/>
                    </padding>

                    <Label text="📋" style="-fx-font-size: 18px;"/>

                    <VBox spacing="1">
                        <Label text="CA Eligibility Result Table"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label fx:id="summaryLabel"
                               text="No records loaded"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <TableView fx:id="caTable"
                           VBox.vgrow="ALWAYS"
                           prefHeight="360"
                           style="-fx-background-color: white;
                                  -fx-border-color: transparent;">

                    <columns>
                        <TableColumn fx:id="regNoColumn" text="Reg No" prefWidth="130"/>
                        <TableColumn fx:id="nameColumn" text="Student Name" prefWidth="180"/>
                        <TableColumn fx:id="courseColumn" text="Course" prefWidth="260"/>
                        <TableColumn fx:id="caMarksColumn" text="CA Marks" prefWidth="100"/>
                        <TableColumn fx:id="caMaxColumn" text="CA Max" prefWidth="100"/>
                        <TableColumn fx:id="caPercentageColumn" text="CA %" prefWidth="100"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <Label fx:id="statusLabel"
                   visible="false"
                   managed="false"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="-fx-background-color: white;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8" bottom="8" left="24" right="24"/>
            </padding>

            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="CA Eligibility Panel"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>