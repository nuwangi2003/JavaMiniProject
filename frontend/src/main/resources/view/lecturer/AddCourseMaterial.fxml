<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.AddCourseMaterialController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f8fbff;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding><Insets left="24"/></padding>

                <Label text="🎓" style="-fx-font-size: 26px;"/>

                <VBox>
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Course Material Upload"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="← Back"
                    onAction="#goBack"
                    style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;
                           -fx-background-radius: 8; -fx-font-weight: bold;
                           -fx-padding: 6 16; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="28">
            <padding><Insets top="30" left="40" right="40" bottom="30"/></padding>

            <!-- HEADER -->
            <VBox spacing="4">
                <Label fx:id="courseNameLabel"
                       text="Add Material"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>

                <Label text="Upload lecture materials (PDF, PPT, Docs) for students."
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
            </VBox>

            <!-- FORM CARD -->
            <VBox spacing="0"
                  style="-fx-background-color: #fafbff;
                         -fx-background-radius: 14;
                         -fx-border-color: #d4e4f7;
                         -fx-border-radius: 14;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">

                <!-- CARD HEADER -->
                <HBox spacing="10"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 14 14 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">
                    <padding><Insets top="18" left="24" right="24" bottom="18"/></padding>

                    <Label text="📄" style="-fx-font-size: 18px;"/>

                    <VBox>
                        <Label text="Material Details"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Enter material information"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <!-- FORM BODY -->
                <VBox spacing="20">
                    <padding><Insets top="28" left="28" right="28" bottom="28"/></padding>

                    <!-- TITLE -->
                    <VBox spacing="7">
                        <Label text="Material Title"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                        <HBox style="-fx-background-color: white;
                                     -fx-border-color: #d4e4f7;
                                     -fx-border-radius: 8;">
                            <Label text="  📝  "
                                   style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;"/>

                            <TextField fx:id="titleField"
                                       promptText="Lecture 01 PDF"
                                       style="-fx-background-color: transparent;
                                              -fx-border-color: transparent;
                                              -fx-font-size: 13px;"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- FILE -->
                    <VBox spacing="7">
                        <Label text="Material File"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <TextField fx:id="filePathField"
                                       editable="false"
                                       promptText="Choose file..."
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #d4e4f7;
                                              -fx-border-radius: 8;
                                              -fx-padding: 8;"/>

                            <Button text="Browse"
                                    onAction="#chooseFile"
                                    style="-fx-background-color: #5b9fd9;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- STATUS -->
                    <Label fx:id="statusLabel"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;"
                           visible="false" managed="false"/>

                    <!-- BUTTONS -->
                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button text="Clear"
                                onAction="#chooseFile"
                                style="-fx-background-color: #e8eef5;
                                       -fx-text-fill: #5b9fd9;
                                       -fx-background-radius: 8;"/>

                        <Button text="Upload Material"
                                onAction="#saveMaterial"
                                style="-fx-background-color: #4cba52;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-padding: 10 20;
                                       -fx-cursor: hand;"/>
                    </HBox>

                </VBox>
            </VBox>
        </VBox>
    </center>

    <!-- BOTTOM BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="-fx-background-color: white; -fx-border-color: #e8eef5; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="8" left="24" right="24" bottom="8"/></padding>

            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label text="System Online  •  LMS  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Material Upload Panel"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>