<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.UploadFinalMarksController"
            prefWidth="950"
            prefHeight="700"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.28), 16, 0, 0, 4);">

            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="74">
                <padding>
                    <Insets left="26" right="26"/>
                </padding>

                <StackPane prefWidth="46" prefHeight="46"
                           style="-fx-background-color: rgba(255,255,255,0.20);
                                  -fx-background-radius: 23;">
                    <Label text="🎓" style="-fx-font-size: 22px;"/>
                </StackPane>

                <VBox spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    <Label text="Final Marks Management"
                           style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets right="24"/>
                </padding>

                <Label text="📝 Upload Final Marks"
                       style="-fx-background-color: rgba(255,255,255,0.18);
                              -fx-text-fill: white;
                              -fx-font-size: 12px;
                              -fx-font-weight: bold;
                              -fx-background-radius: 20;
                              -fx-padding: 8 16;"/>

                <Button text="← Back"
                        onAction="#goBack"
                        style="-fx-background-color: white;
                               -fx-text-fill: #3f7fc2;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 20;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <HBox alignment="CENTER_LEFT"
                  spacing="18"
                  style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff);
                         -fx-background-radius: 18;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 18;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">

                <padding>
                    <Insets top="22" right="24" bottom="22" left="24"/>
                </padding>

                <StackPane prefWidth="58" prefHeight="58"
                           style="-fx-background-color: linear-gradient(to bottom right, #5b9fd9, #7cb7ea);
                                  -fx-background-radius: 29;">
                    <Label text="📊" style="-fx-font-size: 22px;"/>
                </StackPane>

                <VBox spacing="5">
                    <Label text="Upload Student Final Marks"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Select assigned course, enter student registration number, and upload final marks."
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <VBox spacing="0"
                  style="-fx-background-color: #fafbff;
                         -fx-background-radius: 16;
                         -fx-border-color: #d4e4f7;
                         -fx-border-radius: 16;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 16 16 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets top="18" bottom="18" left="24" right="24"/>
                    </padding>

                    <Label text="🧾" style="-fx-font-size: 18px;"/>

                    <VBox spacing="1">
                        <Label text="Final Marks Details"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Only your assigned courses will be shown."
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <VBox spacing="20">
                    <padding>
                        <Insets top="26" bottom="26" left="28" right="28"/>
                    </padding>

                    <VBox spacing="7">
                        <Label text="Course"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                        <ComboBox fx:id="courseBox"
                                  promptText="Select assigned course"
                                  maxWidth="Infinity"
                                  style="-fx-background-color: #ffffff;
                                         -fx-border-color: #d4e4f7;
                                         -fx-border-radius: 8;
                                         -fx-background-radius: 8;
                                         -fx-font-size: 13px;
                                         -fx-padding: 4;"/>
                    </VBox>

                    <HBox spacing="20">
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Student Registration Number"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #d4e4f7;
                                         -fx-border-radius: 8;
                                         -fx-background-radius: 8;">
                                <Label text="  🆔  "
                                       style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;"/>
                                <TextField fx:id="regNoField"
                                           promptText="Example: TG/2021/001"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent;
                                                  -fx-border-color: transparent;
                                                  -fx-font-size: 13px;
                                                  -fx-padding: 10;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Final Marks"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #d4e4f7;
                                         -fx-border-radius: 8;
                                         -fx-background-radius: 8;">
                                <Label text="  🎯  "
                                       style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;"/>
                                <TextField fx:id="marksField"
                                           promptText="0 - 100"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: transparent;
                                                  -fx-border-color: transparent;
                                                  -fx-font-size: 13px;
                                                  -fx-padding: 10;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <Label fx:id="statusLabel"
                           visible="false"
                           managed="false"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button text="Clear"
                                onAction="#clearForm"
                                prefHeight="42"
                                prefWidth="120"
                                style="-fx-background-color: #e8eef5;
                                       -fx-text-fill: #5b9fd9;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-border-color: #d4e4f7;
                                       -fx-border-radius: 8;
                                       -fx-cursor: hand;"/>

                        <Button text="✅ Upload Marks"
                                onAction="#uploadMarks"
                                prefHeight="42"
                                prefWidth="170"
                                style="-fx-background-color: #4cba52;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;"/>

                        <Button text="✏️ Update Marks"
                                onAction="#updateMarks"
                                prefHeight="42"
                                prefWidth="170"
                                style="-fx-background-color: #f59e0b;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox spacing="0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 16;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">

                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 16 16 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets top="16" bottom="16" left="24" right="24"/>
                    </padding>

                    <Label text="📋" style="-fx-font-size: 18px;"/>

                    <VBox spacing="1">
                        <Label text="Recently Uploaded Marks"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Uploaded marks will appear here one by one."
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <TableView fx:id="marksTable"
                           prefHeight="210"
                           style="-fx-background-color: white;
                                  -fx-border-color: transparent;">

                    <columns>
                        <TableColumn fx:id="regNoColumn"
                                     text="Reg No"
                                     prefWidth="220"/>

                        <TableColumn fx:id="courseColumn"
                                     text="Course"
                                     prefWidth="420"/>

                        <TableColumn fx:id="marksColumn"
                                     text="Marks"
                                     prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="-fx-background-color: white;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8" bottom="8" left="24" right="24"/>
            </padding>

            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Final Marks Panel"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>