<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.controller.lecturer.LecturerDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);                      -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12">
                <padding>
                    <Insets bottom="0" left="24" right="0" top="0" />
                </padding>

                <StackPane prefHeight="42" prefWidth="42" style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 21;">
                    <Label style="-fx-font-size: 20px;" text="🎓" />
                </StackPane>

                <VBox spacing="2">
                    <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="FoT Portal" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10px;" text="Lecturer Panel" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets bottom="0" left="12" right="12" top="0" />
                </padding>

                <Button style="-fx-background-color: rgba(255,255,255,0.22);                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-font-weight: bold;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Dashboard" />

                <Button onAction="#openCourses" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="My Courses" />

                <Button onAction="#openMarks" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Marks" />

                <Button onAction="#openStudents" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Students" />

                <Button onAction="#openAttendance" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Attendance" />

                <Button onAction="#openNotices" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Notices" />
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets bottom="0" left="10" right="20" top="0" />
                </padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: white;" />
                    <Label style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;" text="L" />
                </StackPane>

                <VBox spacing="1">
                    <Label fx:id="lecturerNameLabel" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Dr. Lecturer" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;" text="Lecturer" />
                </VBox>

                <Button onAction="#openProfile" style="-fx-background-color: rgba(255,255,255,0.18);                                -fx-text-fill: white;                                -fx-font-size: 12px;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-cursor: hand;                                -fx-border-color: rgba(255,255,255,0.22);                                -fx-border-radius: 8;                                -fx-border-width: 1;" text="My Profile" />

                <Button onAction="#logout" style="-fx-background-color: white;                                -fx-text-fill: #e85d5d;                                -fx-font-size: 12px;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-cursor: hand;" text="Logout" />
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="26" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="28" left="34" right="34" top="28" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="18" style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff);                              -fx-background-radius: 18;                              -fx-border-color: #d7e7f8;                              -fx-border-radius: 18;                              -fx-border-width: 1;                              -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">
                    <padding>
                        <Insets bottom="22" left="24" right="24" top="22" />
                    </padding>

                    <StackPane prefHeight="58" prefWidth="58" style="-fx-background-color: linear-gradient(to bottom right, #5b9fd9, #7cb7ea);                                       -fx-background-radius: 29;">
                        <Label style="-fx-font-size: 22px;" text="👨‍🏫" />
                    </StackPane>

                    <VBox spacing="5">
                        <Label fx:id="welcomeLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 27px; -fx-font-weight: bold;" text="Welcome, Dr. Lecturer 👋" />
                        <Label fx:id="dateLabel" style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;" text="Thursday, March 13, 2026  •  Lecturer Panel" />
                    </VBox>
                </HBox>

                <FlowPane hgap="18" prefWrapLength="1100" vgap="18">

                    <VBox prefHeight="122" prefWidth="210" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #eef8ff, #f8fbff);                                  -fx-background-radius: 16;                                  -fx-border-color: #d8e7f7;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.16), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #468ed0; -fx-font-size: 12px; -fx-font-weight: bold;" text="📚  My Courses" />
                        <Label fx:id="myCoursesLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="4" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="This semester" />
                    </VBox>

                    <VBox prefHeight="122" prefWidth="210" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #effcf4, #f7fff9);                                  -fx-background-radius: 16;                                  -fx-border-color: #cfead7;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(109,186,130,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #35a053; -fx-font-size: 12px; -fx-font-weight: bold;" text="🎓  My Students" />
                        <Label fx:id="myStudentsLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="20" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Assigned students" />
                    </VBox>

                    <VBox prefHeight="122" prefWidth="210" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #f4f7ff, #fbfcff);                                  -fx-background-radius: 16;                                  -fx-border-color: #dde6fb;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(114,137,235,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #5b7ee5; -fx-font-size: 12px; -fx-font-weight: bold;" text="✅  Eligible Students" />
                        <Label fx:id="eligibleLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="16" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Attendance + CA" />
                    </VBox>

                    <VBox prefHeight="122" prefWidth="210" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #fff8ef, #fffdf8);                                  -fx-background-radius: 16;                                  -fx-border-color: #ffe0aa;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(240,170,79,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #d98928; -fx-font-size: 12px; -fx-font-weight: bold;" text="⏳  Pending Marks" />
                        <Label fx:id="pendingMarksLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="2" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Need update" />
                    </VBox>

                </FlowPane>

                <VBox spacing="14" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-border-color: #d7e7f8;                              -fx-border-radius: 16;                              -fx-border-width: 1;                              -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets bottom="22" left="24" right="24" top="22" />
                    </padding>

                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;" text="Quick Actions" />

                    <Separator style="-fx-background-color: #e7eef7;" />

                    <FlowPane hgap="12" vgap="12">
                        <Button onAction="#openFinalMarks" prefHeight="42" prefWidth="180" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="📝  Upload Final Marks" />

                        <Button onAction="#openCA" prefHeight="42" prefWidth="180" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="📊  CA Management" />

                        <Button onAction="#openCaEligibility" prefHeight="42" prefWidth="180" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="📋  CA Eligibility" />

                        <Button onAction="#openAddSession" prefHeight="42" prefWidth="180" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="🗓  Add Session" />

                        <Button onAction="#openEligibility" prefHeight="42" prefWidth="180" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="✅  Check Eligibility" />

                        <Button onAction="#openGrades" prefHeight="42" prefWidth="180" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="📊  Grades &amp; GPA" />
                    </FlowPane>
                </VBox>

                <VBox spacing="14" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-border-color: #d7e7f8;                              -fx-border-radius: 16;                              -fx-border-width: 1;                              -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets bottom="22" left="24" right="24" top="22" />
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;" text="📚  My Assigned Courses" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#openCourses" style="-fx-background-color: transparent;                                        -fx-text-fill: #4c8fce;                                        -fx-font-size: 12px;                                        -fx-font-weight: bold;                                        -fx-cursor: hand;" text="View All →" />
                    </HBox>

                    <Separator style="-fx-background-color: #e7eef7;" />

                    <HBox spacing="0" style="-fx-background-color: #f5f9ff; -fx-background-radius: 10;">
                        <padding>
                            <Insets bottom="10" left="16" right="16" top="10" />
                        </padding>

                        <Label prefWidth="160" style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;" text="Course Code" />
                        <Label prefWidth="300" style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;" text="Course Name" />
                        <Label prefWidth="100" style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;" text="Credits" />
                        <Label prefWidth="100" style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;" text="Students" />
                        <Label prefWidth="120" style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;" text="Action" />
                    </HBox>

                    <VBox fx:id="coursesContainer" spacing="6" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #fbfdff; -fx-border-color: #dfeaf6; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="9" left="24" right="24" top="9" />
            </padding>

            <Label style="-fx-text-fill: #28a745; -fx-font-size: 10px;" text="●" />
            <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="System Online  •  Faculty of Technology Management System  •  v1.0" />

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="statusBarTime" style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="13 March 2026" />
        </HBox>
    </bottom>

</BorderPane>
