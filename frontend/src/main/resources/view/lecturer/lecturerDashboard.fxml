<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.LecturerDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12">
                <padding>
                    <Insets left="24"/>
                </padding>

                <StackPane prefHeight="42" prefWidth="42"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 21;">
                    <Label style="-fx-font-size: 20px;" text="🎓"/>
                </StackPane>

                <VBox spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Lecturer Panel"
                           style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets left="12" right="12"/>
                </padding>

                <Button text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.22);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="My Courses" onAction="#openCourses"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 8 18; -fx-cursor: hand;"/>

                <Button text="Marks" onAction="#openMarks"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 8 18; -fx-cursor: hand;"/>

                <Button text="Students" onAction="#openStudents"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 8 18; -fx-cursor: hand;"/>

                <Button text="Attendance" onAction="#openAttendance"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 8 18; -fx-cursor: hand;"/>

                <Button text="Notices" onAction="#openNotices"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-padding: 8 18; -fx-cursor: hand;"/>
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="10" right="20"/>
                </padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: white;"/>
                    <Label text="L"
                           style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>

                <VBox spacing="1">
                    <Label fx:id="lecturerNameLabel" text="Dr. Lecturer"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label text="Lecturer"
                           style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;"/>
                </VBox>

                <Button text="My Profile" onAction="#openProfile"
                        style="-fx-background-color: rgba(255,255,255,0.18);
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.22);
                               -fx-border-radius: 8;
                               -fx-border-width: 1;"/>

                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: white;
                               -fx-text-fill: #e85d5d;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="26" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="28" right="34" bottom="28" left="34"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="18"
                      style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff);
                             -fx-background-radius: 18;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 18;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <StackPane prefHeight="58" prefWidth="58"
                               style="-fx-background-color: linear-gradient(to bottom right, #5b9fd9, #7cb7ea);
                                      -fx-background-radius: 29;">
                        <Label text="👨‍🏫" style="-fx-font-size: 22px;"/>
                    </StackPane>

                    <VBox spacing="5">
                        <Label fx:id="welcomeLabel" text="Welcome, Dr. Lecturer 👋"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 27px; -fx-font-weight: bold;"/>
                        <Label fx:id="dateLabel" text="Thursday, March 13, 2026  •  Lecturer Panel"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <FlowPane hgap="18" prefWrapLength="1100" vgap="18">

                    <VBox prefHeight="122" prefWidth="210" spacing="8"
                          style="-fx-background-color: linear-gradient(to bottom right, #eef8ff, #f8fbff);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #d8e7f7;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="📚  My Courses"
                               style="-fx-text-fill: #468ed0; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="myCoursesLabel" text="0"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Assigned courses"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox prefHeight="122" prefWidth="210" spacing="8"
                          style="-fx-background-color: linear-gradient(to bottom right, #effcf4, #f7fff9);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #cfead7;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="🎓  My Students"
                               style="-fx-text-fill: #35a053; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="myStudentsLabel" text="-"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Not calculated"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox prefHeight="122" prefWidth="210" spacing="8"
                          style="-fx-background-color: linear-gradient(to bottom right, #f4f7ff, #fbfcff);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #dde6fb;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="✅  Eligible Students"
                               style="-fx-text-fill: #5b7ee5; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="eligibleLabel" text="-"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Not calculated"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox prefHeight="122" prefWidth="210" spacing="8"
                          style="-fx-background-color: linear-gradient(to bottom right, #fff8ef, #fffdf8);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #ffe0aa;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="⏳  Pending Marks"
                               style="-fx-text-fill: #d98928; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="pendingMarksLabel" text="-"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Not calculated"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <Label text="Quick Actions"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Separator/>

                    <FlowPane hgap="12" vgap="12">
                        <Button text="📝  Upload Final Marks" onAction="#openFinalMarks"
                                prefHeight="42" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="📊  CA Management" onAction="#openCA"
                                prefHeight="42" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="📋  CA Eligibility" onAction="#openCaEligibility"
                                prefHeight="42" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="🗓  Add Session" onAction="#openAddSession"
                                prefHeight="42" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="✅  Check Eligibility" onAction="#openEligibility"
                                prefHeight="42" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="📊  Grades &amp; GPA" onAction="#openGrades"
                                prefHeight="42" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </FlowPane>
                </VBox>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="📚  My Assigned Courses"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="View All →" onAction="#openCourses"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #4c8fce;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <Separator/>

                    <HBox spacing="0" style="-fx-background-color: #f5f9ff; -fx-background-radius: 10;">
                        <padding>
                            <Insets top="10" right="16" bottom="10" left="16"/>
                        </padding>

                        <Label text="Course Code" prefWidth="160"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Course Name" prefWidth="300"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Credits" prefWidth="100"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Action" prefWidth="120"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>

                    <VBox fx:id="coursesContainer" spacing="6"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #fbfdff; -fx-border-color: #dfeaf6; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="9" right="24" bottom="9" left="24"/>
            </padding>

            <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 10px;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusBarTime" text="13 March 2026"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>