                      style="-fx-background-color: #142033;
                             -fx-background-radius: 20;
                             -fx-border-color: #29405f;
                             -fx-border-radius: 20;
                             -fx-border-width: 1;
                             -fx-padding: 6 14 6 12;">
                    <StackPane prefWidth="7" prefHeight="7"
                               style="-fx-background-color: #22c55e;
                                      -fx-background-radius: 4;
                                      -fx-effect: dropshadow(gaussian,#22c55e,6,0.6,0,0);"/>
