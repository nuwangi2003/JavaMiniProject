                               -fx-border-color: #35517b;
                               -fx-border-width: 1;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-font-size: 11px;
                               -fx-font-family: 'Consolas';
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-padding: 8 16 8 16;"/>
