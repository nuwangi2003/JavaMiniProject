<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.LecturerDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #0f1b35;">

    <!-- ═══════════════════════ TOP NAV BAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="🎓" style="-fx-font-size: 26px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Nav -->
            <HBox spacing="4" alignment="CENTER">
                <padding><Insets left="16" right="16"/></padding>
                <Button text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                <Button text="My Courses" onAction="#openCourses"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Marks" onAction="#openMarks"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Students" onAction="#openStudents"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Eligibility" onAction="#openEligibility"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Attendance" onAction="#openAttendance"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Notices" onAction="#openNotices"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <Separator orientation="VERTICAL"/>

            <!-- User -->
            <HBox alignment="CENTER" spacing="10">
                <padding><Insets left="16" right="20"/></padding>
                <StackPane>
                    <Circle radius="18" style="-fx-fill: linear-gradient(to bottom right, #c0622a, #7b2d00);"/>
                    <Label text="L" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="lecturerNameLabel" text="Dr. Lecturer"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Lecturer" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
                <Button text="My Profile" onAction="#openProfile"
                        style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER">
            <VBox spacing="28" style="-fx-background-color: #0f1b35;">
                <padding><Insets top="30" bottom="30" left="36" right="36"/></padding>

                <!-- Welcome -->
                <VBox spacing="4">
                    <Label fx:id="welcomeLabel" text="Welcome, Dr. Lecturer 👋"
                           style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label fx:id="dateLabel" text="Thursday, March 13, 2026  •  Lecturer Panel"
                           style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Stat Cards -->
                <FlowPane hgap="18" vgap="18" prefWrapLength="1200">

                    <VBox spacing="8" prefWidth="210" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #7b2d00, #c0622a); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📚  My Courses" style="-fx-text-fill: #ffd8b1; -fx-font-size: 12px;"/>
                        <Label fx:id="myCoursesLabel" text="4"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="This semester" style="-fx-text-fill: #ffb347; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="210" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #155724, #1e7e34); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="🎓  My Students" style="-fx-text-fill: #a8e6cf; -fx-font-size: 12px;"/>
                        <Label fx:id="myStudentsLabel" text="20"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Enrolled undergrads" style="-fx-text-fill: #74c69d; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="210" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #1e3c72, #2a5298); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="✅  Eligible Students" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px;"/>
                        <Label fx:id="eligibleLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="CA ≥ 40% + Attendance" style="-fx-text-fill: #64b5f6; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="210" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #4a0072, #7b1fa2); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="⏳  Marks Pending" style="-fx-text-fill: #e1b3ff; -fx-font-size: 12px;"/>
                        <Label fx:id="pendingMarksLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Awaiting upload" style="-fx-text-fill: #ce93d8; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <!-- Quick Actions -->
                <VBox spacing="14"
                      style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                    <Label text="Quick Actions"
                           style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Separator style="-fx-background-color: #1e3c72;"/>
                    <FlowPane hgap="12" vgap="12">
                        <Button text="📝  Upload Marks" onAction="#openMarks" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📋  View Attendance" onAction="#openAttendance" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✅  Check Eligibility" onAction="#openEligibility" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📊  Grades &amp; GPA" onAction="#openGrades" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📖  Course Materials" onAction="#openCourses" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                        <Button text="📝  Upload Final Marks" onAction="#openUploadFinalMarks" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✏️  Update Final Marks" onAction="#openUpdateFinalMarks" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📦  Batch Final Marks" onAction="#openBatchFinalMarks" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📊  Generate Grades" onAction="#openGenerateGrades" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📑  Batch Grades" onAction="#openBatchGrades" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✅  Batch Eligibility" onAction="#openBatchEligibility" prefHeight="42" prefWidth="180"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
            
                    </FlowPane>
                </VBox>

                <!-- My Courses Table Header -->
                <VBox spacing="14"
                      style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="📚  My Assigned Courses"
                               style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="View All →" onAction="#openCourses"
                                style="-fx-background-color: transparent; -fx-text-fill: #4a90d9; -fx-font-size: 12px; -fx-cursor: hand;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1e3c72;"/>
                    <!-- Column headers -->
                    <HBox spacing="0" style="-fx-background-color: #1e3c72; -fx-background-radius: 8;">
                        <padding><Insets top="10" bottom="10" left="16" right="16"/></padding>
                        <Label text="Course Code" prefWidth="160" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Course Name" prefWidth="300" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Credits" prefWidth="100" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Students" prefWidth="100" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label text="Action" prefWidth="120" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>
                    <VBox fx:id="coursesContainer" spacing="6"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>
            <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 10px;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text="13 March 2026" style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>