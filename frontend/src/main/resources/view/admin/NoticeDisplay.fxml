<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.DisplayNoticeController"
            prefWidth="1000.0"
            prefHeight="600.0"
            style="-fx-background-color: #f8fbff;">

    <!-- TOP -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="0"
              prefHeight="64"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <!-- Left logo section -->
            <HBox alignment="CENTER_LEFT"
                  spacing="12"
                  prefHeight="64"
                  style="-fx-background-color: #ffffff;">
                <padding>
                    <Insets top="12" right="24" bottom="12" left="28"/>
                </padding>
                <children>
                    <Label text="🎓" style="-fx-font-size: 24px;"/>
                    <VBox alignment="CENTER_LEFT" spacing="2">
                        <children>
                            <Label text="FoT Portal"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Label text="Faculty of Technology"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Center title -->
            <HBox alignment="CENTER" spacing="8">
                <padding>
                    <Insets top="0" right="16" bottom="0" left="16"/>
                </padding>
                <children>
                    <Label text="📢" style="-fx-font-size: 16px;"/>
                    <Label text="Notice Management"
                           style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </children>
            </HBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #e8eef5;"/>

            <!-- Right user section -->
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <padding>
                    <Insets top="0" right="24" bottom="0" left="16"/>
                </padding>
                <children>
                    <StackPane>
                        <children>
                            <Circle radius="18" style="-fx-fill: #4cba52;"/>
                            <Label text="A"
                                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        </children>
                    </StackPane>

                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <children>
                            <Label fx:id="adminNameLabel"
                                   text="Administrator"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <Label text="Admin"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 9px;"/>
                        </children>
                    </VBox>

                    <Button text="← Back"
                            onAction="#goBack"
                            style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-border-color: #d4e4f7; -fx-border-radius: 6; -fx-border-width: 1; -fx-padding: 6 16 6 16;"/>
                </children>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="16" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <children>
                <!-- Page heading -->
                <VBox spacing="4">
                    <children>
                        <Label text="Notice Management"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="View all notices and inspect selected notice details."
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                    </children>
                </VBox>

                <!-- Search / Action row -->
                <HBox spacing="14" alignment="BOTTOM_LEFT">
                    <children>
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Search by Title"
                                       style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="searchField"
                                           promptText="Type notice title..."
                                           onKeyReleased="#filterNotices"
                                           prefHeight="42"
                                           style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52; -fx-prompt-text-fill: #a8b8ca; -fx-font-size: 12px; -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;"/>
                            </children>
                        </VBox>

                        <VBox spacing="7">
                            <children>
                                <Label text="Actions"
                                       style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <Button text="⟳ Refresh"
                                        onAction="#refreshNotices"
                                        prefHeight="42" prefWidth="120"
                                        style="-fx-background-color: #5b9fd9; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Main section -->
                <HBox spacing="16" VBox.vgrow="ALWAYS">
                    <children>

                        <!-- LEFT PANEL -->
                        <VBox spacing="0"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #fafbff; -fx-background-radius: 14; -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1.5; -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">
                            <children>

                                <!-- Left header -->
                                <HBox alignment="CENTER_LEFT"
                                      spacing="10"
                                      style="-fx-background-color: #f5f9ff; -fx-background-radius: 14 14 0 0; -fx-border-color: transparent transparent #e8eef5 transparent; -fx-border-width: 0 0 1 0;">
                                    <padding>
                                        <Insets top="16" right="20" bottom="16" left="20"/>
                                    </padding>
                                    <children>
                                        <StackPane>
                                            <children>
                                                <Circle radius="16" style="-fx-fill: rgba(91,159,217,0.15);"/>
                                                <Label text="📢" style="-fx-font-size: 16px;"/>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2">
                                            <children>
                                                <Label text="Notices List"
                                                       style="-fx-text-fill: #1a3a52; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                <Label fx:id="totalNoticesInfoLabel"
                                                       text="0 notices loaded"
                                                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Scroll area -->
                                <ScrollPane fx:id="noticeScrollPane"
                                            fitToWidth="true"
                                            VBox.vgrow="ALWAYS"
                                            hbarPolicy="NEVER"
                                            style="-fx-background: transparent; -fx-background-color: transparent;">
                                    <content>
                                        <VBox fx:id="noticeListContainer"
                                              spacing="12"
                                              style="-fx-background-color: transparent;">
                                            <padding>
                                                <Insets top="16" right="16" bottom="16" left="16"/>
                                            </padding>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <!-- RIGHT PANEL -->
                        <VBox prefWidth="280"
                              minWidth="280"
                              maxWidth="280"
                              spacing="0"
                              style="-fx-background-color: #fafbff; -fx-background-radius: 14; -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1.5; -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">
                            <children>

                                <!-- Right header -->
                                <HBox alignment="CENTER_LEFT"
                                      spacing="10"
                                      style="-fx-background-color: #f5f9ff; -fx-background-radius: 14 14 0 0; -fx-border-color: transparent transparent #e8eef5 transparent; -fx-border-width: 0 0 1 0;">
                                    <padding>
                                        <Insets top="16" right="20" bottom="16" left="20"/>
                                    </padding>
                                    <children>
                                        <StackPane>
                                            <children>
                                                <Circle radius="16" style="-fx-fill: rgba(91,159,217,0.15);"/>
                                                <Label text="🧾" style="-fx-font-size: 16px;"/>
                                            </children>
                                        </StackPane>
                                        <VBox spacing="2">
                                            <children>
                                                <Label text="Notice Details"
                                                       style="-fx-text-fill: #1a3a52; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                <Label text="Click a card to view"
                                                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="14" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets top="20" right="18" bottom="20" left="18"/>
                                    </padding>

                                    <children>
                                        <StackPane>
                                            <children>
                                                <Circle radius="32" style="-fx-fill: #5b9fd9;"/>
                                                <Label text="N"
                                                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                                            </children>
                                        </StackPane>

                                        <VBox spacing="6" alignment="CENTER">
                                            <children>
                                                <Label fx:id="detailTitleLabel"
                                                       text="Select a notice"
                                                       wrapText="true"
                                                       maxWidth="240"
                                                       style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold; -fx-alignment: center;"/>
                                                <Label text="Notice"
                                                       style="-fx-background-color: #f5f9ff; -fx-text-fill: #5b9fd9; -fx-padding: 4 12 4 12; -fx-background-radius: 20; -fx-border-color: #d4e4f7; -fx-border-radius: 20; -fx-border-width: 1; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                            </children>
                                        </VBox>

                                        <Separator style="-fx-background-color: #e8eef5;"/>

                                        <VBox spacing="12">
                                            <children>
                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Notice ID"
                                                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailIdLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Description"
                                                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailDescriptionLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Created By"
                                                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailCreatedByLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Created At"
                                                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailCreatedAtLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="PDF File"
                                                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Hyperlink fx:id="detailPdfLink"
                                                                   text="Open attached PDF"
                                                                   onAction="#openSelectedNoticePdf"
                                                                   wrapText="true"
                                                                   style="-fx-text-fill: #5b9fd9; -fx-font-size: 12px; -fx-font-weight: 600;"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <Region VBox.vgrow="ALWAYS"/>

                                        <Button text="Open PDF"
                                                onAction="#openSelectedNoticePdf"
                                                maxWidth="Infinity"
                                                prefHeight="40"
                                                style="-fx-background-color: #4cba52; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              prefHeight="40"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8" right="28" bottom="8" left="28"/>
            </padding>
            <children>
                <Circle radius="4" style="-fx-fill: #4cba52;"/>
                <Label fx:id="statusLabel"
                       text="Ready"
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusBarTime"
                       text="Time"
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>