<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.DisplayNoticeController"
            prefWidth="1000.0"
            prefHeight="600.0"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="64"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="0" right="24" bottom="0" left="28"/>
            </padding>

            <Label text="🎓" style="-fx-font-size: 24px;"/>

            <VBox spacing="2">
                <padding>
                    <Insets left="12"/>
                </padding>
                <Label text="FoT Portal"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="Notice List"
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <StackPane>
                <Circle radius="18" style="-fx-fill: #4cba52;"/>
                <Label text="U"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </StackPane>

            <VBox spacing="1">
                <padding>
                    <Insets left="10" right="14"/>
                </padding>
                <Label fx:id="adminNameLabel"
                       text="User"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Label text="Portal User"
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 9px;"/>
            </VBox>

            <Button text="← Back"
                    onAction="#goBack"
                    style="-fx-background-color: #e8eef5;
                           -fx-text-fill: #5b9fd9;
                           -fx-font-size: 11px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;
                           -fx-border-color: #d4e4f7;
                           -fx-border-radius: 6;
                           -fx-border-width: 1;
                           -fx-padding: 6 16 6 16;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <VBox spacing="4">
                <Label text="📢 Notices"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Label text="All notices are shown below. Use Open to view the attached PDF."
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
            </VBox>

            <HBox spacing="14" alignment="BOTTOM_LEFT">
                <VBox spacing="7" HBox.hgrow="ALWAYS">
                    <Label text="Search Notice"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="searchField"
                               promptText="Search by title or description..."
                               onKeyReleased="#filterNotices"
                               prefHeight="42"
                               style="-fx-background-color: #ffffff;
                                      -fx-text-fill: #1a3a52;
                                      -fx-prompt-text-fill: #a8b8ca;
                                      -fx-font-size: 12px;
                                      -fx-border-color: #d4e4f7;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-border-width: 1;"/>
                </VBox>

                <VBox spacing="7">
                    <Label text="Action"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Button text="⟳ Refresh"
                            onAction="#refreshNotices"
                            prefHeight="42"
                            prefWidth="120"
                            style="-fx-background-color: #5b9fd9;
                                   -fx-text-fill: white;
                                   -fx-font-size: 12px;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                </VBox>
            </HBox>

            <VBox spacing="0"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #fafbff;
                         -fx-background-radius: 14;
                         -fx-border-color: #d4e4f7;
                         -fx-border-radius: 14;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">

                <HBox alignment="CENTER_LEFT"
                      spacing="10"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 14 14 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets top="16" right="20" bottom="16" left="20"/>
                    </padding>

                    <Circle radius="6" style="-fx-fill: #5b9fd9;"/>

                    <VBox spacing="2">
                        <Label text="Notice List"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalNoticesInfoLabel"
                               text="0 notices loaded"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>

                <ScrollPane fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            hbarPolicy="NEVER"
                            style="-fx-background: transparent; -fx-background-color: transparent;">
                    <VBox fx:id="noticeListContainer"
                          spacing="12"
                          style="-fx-background-color: transparent;">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                    </VBox>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              prefHeight="40"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8" right="28" bottom="8" left="28"/>
            </padding>

            <Circle radius="4" style="-fx-fill: #4cba52;"/>

            <Label fx:id="statusLabel"
                   text="Ready"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusBarTime"
                   text="Time"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>