<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.DisplayTimeTableController"
            prefWidth="820.0"
            prefHeight="620.0"
            style="-fx-background-color: #f8fbff;">

    <!-- ══════════════════════════  TOP NAV  ══════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="64"
              spacing="0"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <!-- LEFT: Brand -->
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64">
                <padding>
                    <Insets top="0" right="24" bottom="0" left="28"/>
                </padding>

                <Label text="🎓" style="-fx-font-size: 26px;"/>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <!-- CENTER -->
            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="0" right="24" bottom="0" left="24"/>
                </padding>

                <Label text="🗓" style="-fx-font-size: 16px;"/>

                <Label text="Time Table Management"
                       style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- RIGHT -->
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <padding>
                    <Insets top="0" right="24" bottom="0" left="16"/>
                </padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: #5b9fd9;"/>
                    <Label text="A"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </StackPane>

                <Label fx:id="adminNameLabel"
                       text="Administrator"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                <Button text="← Back"
                        onAction="#goBack"
                        style="-fx-background-color: #e8eef5;
                               -fx-text-fill: #5b9fd9;
                               -fx-font-size: 12px;
                               -fx-border-color: #d4e4f7;
                               -fx-border-radius: 6;
                               -fx-background-radius: 6;
                               -fx-cursor: hand;
                               -fx-padding: 6 16 6 16;
                               -fx-font-weight: 600;"/>
            </HBox>

        </HBox>
    </top>

    <!-- ══════════════════════════  MAIN CONTENT  ══════════════════════════ -->
    <center>
        <VBox spacing="0">
            <padding><Insets top="28" right="32" bottom="16" left="32"/></padding>

            <!-- Page heading -->
            <VBox spacing="6">
                <Label text="Time Tables"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Label text="Browse, search and open any timetable PDF below."
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
            </VBox>

            <Region prefHeight="20"/>

            <!-- Search bar -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="🔍  Search by title, department, semester or level…"
                           onKeyReleased="#filterTimeTables"
                           HBox.hgrow="ALWAYS"
                           prefHeight="44"
                           style="-fx-background-color: #ffffff;
                                  -fx-text-fill: #1a3a52;
                                  -fx-prompt-text-fill: #a8b8ca;
                                  -fx-font-size: 12px;
                                  -fx-border-color: #d4e4f7;
                                  -fx-border-radius: 10;
                                  -fx-background-radius: 10;
                                  -fx-padding: 10 16 10 16;
                                  -fx-border-width: 1;"/>
                <Button text="⟳ Refresh"
                        onAction="#refreshTimeTables"
                        prefHeight="44" prefWidth="130"
                        style="-fx-background-color: #5b9fd9;
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-border-color: transparent;
                               -fx-border-radius: 10;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>
            </HBox>

            <Region prefHeight="8"/>

            <!-- Count label -->
            <Label fx:id="totalTimeTablesInfoLabel"
                   text="0 time tables loaded"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region prefHeight="14"/>

            <!-- LIST -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                        prefHeight="420">
                <content>
                    <VBox fx:id="timetableListContainer"
                          spacing="10"
                          style="-fx-background-color: transparent;">
                        <padding><Insets top="2" right="4" bottom="12" left="2"/></padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ══════════════════════════  STATUS BAR  ══════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              prefHeight="40"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="8" right="28" bottom="8" left="28"/></padding>
            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label fx:id="statusLabel"
                   text="Ready"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime"
                   text="--:--:--"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>