<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.AssignLecturerCourseController"
            prefWidth="900" prefHeight="660"
            style="-fx-background-color: #f8fbff;">

    <!-- ═══════════════════════  TOP NAV BAR  ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68" spacing="0"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 0 0 1 0;">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="68">
                <padding><Insets left="28" right="32"/></padding>
                <StackPane>
                    <Circle radius="20" style="-fx-fill: #5b9fd9;"/>
                    <Label text="🎓" style="-fx-font-size: 22px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #e8eef5;"/>

            <!-- Page Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="⟳" style="-fx-font-size: 16px; -fx-text-fill: #5b9fd9;"/>
                <Label text="Assign Lecturer to Course"
                       style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Admin Info -->
            <HBox alignment="CENTER" spacing="12">
                <padding><Insets left="20" right="12"/></padding>
                <StackPane>
                    <Circle radius="18" style="-fx-fill: #4cba52;"/>
                    <Label text="A"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="adminNameLabel" text="Administrator"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Admin"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <!-- Back Button -->
            <HBox alignment="CENTER">
                <padding><Insets left="12" right="24"/></padding>
                <Button text="← Back" onAction="#goBack"
                        prefHeight="40" prefWidth="100"
                        style="-fx-background-color: #e8eef5;
                               -fx-text-fill: #5b9fd9;
                               -fx-font-size: 12px;
                               -fx-border-color: #d4e4f7;
                               -fx-border-radius: 8; -fx-border-width: 1;
                               -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════  MAIN CONTENT  ═══════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

            <VBox spacing="0" style="-fx-background-color: #f8fbff;">
                <padding><Insets top="40" bottom="40" left="60" right="60"/></padding>

                <!-- Page Heading -->
                <VBox spacing="8">
                    <padding><Insets bottom="32"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane>
                            <Circle radius="20" style="-fx-fill: rgba(91,159,217,0.15); -fx-border-color: #d4e4f7; -fx-border-width: 1; -fx-border-radius: 20;"/>
                            <Label text="🔗" style="-fx-font-size: 22px;"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="Assign Lecturer to Course"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="Select a lecturer and course to create a teaching assignment"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ─── Main Card ─── -->
                <VBox spacing="0"
                      style="-fx-background-color: #fafbff;
                             -fx-background-radius: 16;
                             -fx-border-color: #d4e4f7;
                             -fx-border-radius: 16;
                             -fx-border-width: 1.5;
                             -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">

                    <!-- Card Header -->
                    <HBox alignment="CENTER_LEFT" spacing="14"
                          style="-fx-background-color: #f5f9ff;
                                 -fx-background-radius: 16 16 0 0;
                                 -fx-border-color: transparent transparent #e8eef5 transparent;
                                 -fx-border-width: 0 0 1 0;">
                        <padding><Insets top="20" bottom="20" left="28" right="28"/></padding>

                        <StackPane>
                            <Circle radius="18" style="-fx-fill: rgba(91,159,217,0.15);"/>
                            <Label text="📚" style="-fx-font-size: 16px;"/>
                        </StackPane>

                        <VBox spacing="3">
                            <Label text="Assignment Configuration"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Label text="Link a lecturer with a course for the current term"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="Required fields marked *"
                               style="-fx-text-fill: #5b9fd9; -fx-font-size: 10px;"/>
                    </HBox>

                    <!-- Card Body -->
                    <VBox spacing="28">
                        <padding><Insets top="34" bottom="34" left="34" right="34"/></padding>

                        <!-- Two column row -->
                        <HBox spacing="24" alignment="CENTER_LEFT">

                            <!-- Lecturer ComboBox -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="Lecturer"
                                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                    <Label text="*"
                                           style="-fx-text-fill: #e85d5d; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                </HBox>
                                <ComboBox fx:id="lecturerBox"
                                          promptText="— Select a Lecturer —"
                                          maxWidth="Infinity"
                                          prefHeight="46"
                                          visibleRowCount="8"
                                          style="-fx-background-color: #ffffff;
                                                 -fx-background-radius: 10;
                                                 -fx-border-color: #d4e4f7;
                                                 -fx-border-radius: 10;
                                                 -fx-border-width: 1;
                                                 -fx-text-fill: #1a3a52;
                                                 -fx-font-size: 13px;
                                                 -fx-padding: 0 14 0 14;"/>
                                <Label text="Choose the faculty member to assign"
                                       style="-fx-text-fill: #a8b8ca; -fx-font-size: 10px;"/>
                            </VBox>

                            <!-- Arrow Icon -->
                            <VBox alignment="CENTER">
                                <padding><Insets top="22"/></padding>
                                <Label text="→"
                                       style="-fx-text-fill: #d4e4f7; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                            </VBox>

                            <!-- Course ComboBox -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <Label text="Course"
                                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                    <Label text="*"
                                           style="-fx-text-fill: #e85d5d; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                </HBox>
                                <ComboBox fx:id="courseBox"
                                          promptText="— Select a Course —"
                                          maxWidth="Infinity"
                                          prefHeight="46"
                                          visibleRowCount="8"
                                          style="-fx-background-color: #ffffff;
                                                 -fx-background-radius: 10;
                                                 -fx-border-color: #d4e4f7;
                                                 -fx-border-radius: 10;
                                                 -fx-border-width: 1;
                                                 -fx-text-fill: #1a3a52;
                                                 -fx-font-size: 13px;
                                                 -fx-padding: 0 14 0 14;"/>
                                <Label text="Choose the course to be taught"
                                       style="-fx-text-fill: #a8b8ca; -fx-font-size: 10px;"/>
                            </VBox>
                        </HBox>

                        <!-- Divider -->
                        <HBox>
                            <Region prefHeight="1"
                                    style="-fx-background-color: #e8eef5;"
                                    HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Status Label -->
                        <HBox alignment="CENTER_LEFT" spacing="8" minHeight="28">
                            <Label fx:id="statusLabel" text=""
                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"
                                   visible="true" managed="true" wrapText="true"/>
                        </HBox>

                        <!-- Action Buttons -->
                        <HBox spacing="14" alignment="CENTER_RIGHT">
                            <Button text="Clear Selection" onAction="#clearSelections"
                                    prefHeight="44" prefWidth="155"
                                    style="-fx-background-color: #e8eef5;
                                           -fx-text-fill: #5b9fd9;
                                           -fx-font-size: 13px;
                                           -fx-background-radius: 10;
                                           -fx-border-color: #d4e4f7;
                                           -fx-border-radius: 10;
                                           -fx-border-width: 1;
                                           -fx-cursor: hand; -fx-font-weight: 600;"/>

                            <Button text="✔  Assign Lecturer" onAction="#assignLecturerCourse"
                                    prefHeight="44" prefWidth="185"
                                    style="-fx-background-color: #5b9fd9;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.2),10,0,0,3);"/>
                        </HBox>

                    </VBox>
                </VBox>

                <!-- Info Strip -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <padding><Insets top="20"/></padding>
                    <Label text="ℹ"
                           style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;"/>
                    <Label text="Each lecturer may be assigned to multiple courses. Duplicate assignments will be rejected by the server."
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="40"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 1 0 0 0;">
            <padding><Insets left="28" right="28"/></padding>
            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label text="System Online"
                   style="-fx-text-fill: #4cba52; -fx-font-size: 10px;"/>
            <Label text="•"
                   style="-fx-text-fill: #e8eef5; -fx-font-size: 10px;"/>
            <Label text="Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text=""
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
        </HBox>
    </bottom>

</BorderPane>