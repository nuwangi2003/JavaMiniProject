<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.CourseDisplayController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68" spacing="0"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="68">
                <padding>
                    <Insets left="28" right="32"/>
                </padding>
                <StackPane>
                    <Circle radius="20" style="-fx-fill: #5b9fd9;"/>
                    <Label text="🎓" style="-fx-font-size: 18px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #e8eef5;"/>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets left="24" right="24"/>
                </padding>
                <Label text="📘" style="-fx-font-size: 16px;"/>
                <Label text="Course Display"
                       style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="12">
                <padding>
                    <Insets left="20" right="12"/>
                </padding>
                <StackPane>
                    <Circle radius="20" style="-fx-fill: #4cba52;"/>
                    <Label text="A"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="adminNameLabel" text="Administrator"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Admin"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER">
                <padding>
                    <Insets left="12" right="24"/>
                </padding>
                <Button text="← Back"
                        onAction="#goBack"
                        prefHeight="36" prefWidth="100"
                        style="-fx-background-color: #e8eef5;
                               -fx-text-fill: #5b9fd9;
                               -fx-font-size: 12px;
                               -fx-border-color: #d4e4f7;
                               -fx-border-radius: 6; -fx-border-width: 1;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-background-color: #f8fbff;">
            <padding>
                <Insets top="40" bottom="20" left="60" right="60"/>
            </padding>

            <VBox spacing="6">
                <padding>
                    <Insets bottom="24"/>
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane>
                        <Circle radius="20" style="-fx-fill: rgba(91,159,217,0.15); -fx-border-color: #d4e4f7; -fx-border-width: 1; -fx-border-radius: 20;"/>
                        <Label text="📚" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="4">
                        <Label text="Course Display"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="View and filter all available courses by name, level, and semester"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="0" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: #fafbff;
                         -fx-background-radius: 16;
                         -fx-border-color: #d4e4f7;
                         -fx-border-radius: 16;
                         -fx-border-width: 1.5;
                         -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.1),12,0,0,4);">

                <HBox alignment="CENTER_LEFT" spacing="14"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 16 16 0 0;
                             -fx-border-color: transparent transparent #e8eef5 transparent;
                             -fx-border-width: 0 0 1 0;">
                    <padding>
                        <Insets top="20" bottom="20" left="28" right="28"/>
                    </padding>

                    <StackPane>
                        <Circle radius="18" style="-fx-fill: rgba(91,159,217,0.15);"/>
                        <Label text="📘" style="-fx-font-size: 16px;"/>
                    </StackPane>

                    <VBox spacing="3">
                        <Label text="Course Records"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Label text="Browse and filter course information"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label text="Use filters to narrow results"
                           style="-fx-text-fill: #5b9fd9; -fx-font-size: 10px;"/>
                </HBox>

                <VBox spacing="20" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="24" bottom="20" left="28" right="28"/>
                    </padding>

                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <Label text="Search Course"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="searchField"
                                       promptText="Search by course name or code..."
                                       prefHeight="44"
                                       style="-fx-background-color: #ffffff;
                                              -fx-background-radius: 10;
                                              -fx-border-color: #d4e4f7;
                                              -fx-border-radius: 10;
                                              -fx-border-width: 1;
                                              -fx-text-fill: #1a3a52;
                                              -fx-prompt-text-fill: #a8b8ca;
                                              -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Level"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="levelFilter"
                                      promptText="All Levels"
                                      prefWidth="150"
                                      prefHeight="44"
                                      style="-fx-background-color: #ffffff;
                                             -fx-background-radius: 10;
                                             -fx-border-color: #d4e4f7;
                                             -fx-border-radius: 10;
                                             -fx-border-width: 1;
                                             -fx-text-fill: #1a3a52;
                                             -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Semester"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="semesterFilter"
                                      promptText="All Semesters"
                                      prefWidth="160"
                                      prefHeight="44"
                                      style="-fx-background-color: #ffffff;
                                             -fx-background-radius: 10;
                                             -fx-border-color: #d4e4f7;
                                             -fx-border-radius: 10;
                                             -fx-border-width: 1;
                                             -fx-text-fill: #1a3a52;
                                             -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="8">
                            <Label text="Action"
                                   style="-fx-text-fill: transparent; -fx-font-size: 12px;"/>
                            <Button text="⟳ Refresh"
                                    onAction="#refreshCourses"
                                    prefHeight="44" prefWidth="130"
                                    style="-fx-background-color: #5b9fd9;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.2),10,0,0,3);"/>
                        </VBox>
                    </HBox>

                    <Separator style="-fx-background-color: #e8eef5;"/>

                    <VBox spacing="10" VBox.vgrow="ALWAYS">
                        <Label text="Available Courses"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>

                        <TableView fx:id="courseTable"
                                   VBox.vgrow="ALWAYS"
                                   maxHeight="1.7976931348623157E308"
                                   style="-fx-background-color: #ffffff;
                                          -fx-control-inner-background: #ffffff;
                                          -fx-table-cell-border-color: #e8eef5;
                                          -fx-border-color: #d4e4f7;
                                          -fx-border-radius: 10;
                                          -fx-background-radius: 10;
                                          -fx-font-size: 12px;
                                          -fx-text-fill: #1a3a52;">
                            <columns>
                                <TableColumn fx:id="colCourseId" text="Course ID" prefWidth="110"/>
                                <TableColumn fx:id="colCourseCode" text="Course Code" prefWidth="140"/>
                                <TableColumn fx:id="colName" text="Course Name" prefWidth="280"/>
                                <TableColumn fx:id="colCredit" text="Credit" prefWidth="90"/>
                                <TableColumn fx:id="colLevel" text="Level" prefWidth="90"/>
                                <TableColumn fx:id="colSemester" text="Semester" prefWidth="110"/>
                                <TableColumn fx:id="colDepartmentId" text="Department" prefWidth="140"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="8" minHeight="28">
                        <Label fx:id="statusLabel"
                               text="Loading courses..."
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #5b9fd9;"/>
                    </HBox>
                </VBox>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="16"/>
                </padding>
                <Label text="ℹ" style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;"/>
                <Label text="Use the search field and filters to quickly find courses by name, academic level, or semester."
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="36"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets left="28" right="28"/>
            </padding>
            <Circle radius="5" style="-fx-fill: #4cba52;"/>
            <Label text="System Online"
                   style="-fx-text-fill: #4cba52; -fx-font-size: 10px;"/>
            <Label text="•"
                   style="-fx-text-fill: #e8eef5; -fx-font-size: 10px;"/>
            <Label text="Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime"
                   text=""
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
        </HBox>
    </bottom>
</BorderPane>