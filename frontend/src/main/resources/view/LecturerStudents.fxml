<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.LecturerStudentsController"
            prefWidth="900" prefHeight="620"
            style="-fx-background-color: #0f1b35;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>
            <Label text="Students"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Back Dashboard" onAction="#backToDashboard"
                    style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" style="-fx-padding: 28;">
            <VBox spacing="10" style="-fx-background-color: #162040; -fx-background-radius: 12;">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Find Student by User ID"
                       style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <HBox spacing="10">
                    <TextField fx:id="studentIdField" promptText="Student user ID" HBox.hgrow="ALWAYS"/>
                    <Button text="Search" onAction="#findStudent"
                            style="-fx-background-color: #2a5298; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
                <Label fx:id="statusLabel" text="Enter a student ID to view details."
                       style="-fx-text-fill: #9bb4da; -fx-font-size: 12px;"/>
            </VBox>

            <VBox spacing="14" style="-fx-background-color: #162040; -fx-background-radius: 12;">
                <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
                <Label text="Student Details"
                       style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <Separator/>
                <GridPane hgap="14" vgap="12">
                    <Label text="Name" style="-fx-text-fill: white;"/>
                    <Label fx:id="nameValue" text="-" GridPane.columnIndex="1" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="User ID" GridPane.rowIndex="1" style="-fx-text-fill: white;"/>
                    <Label fx:id="userIdValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="Reg No" GridPane.rowIndex="2" style="-fx-text-fill: white;"/>
                    <Label fx:id="regNoValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="Batch" GridPane.rowIndex="3" style="-fx-text-fill: white;"/>
                    <Label fx:id="batchValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="Academic Level" GridPane.rowIndex="4" style="-fx-text-fill: white;"/>
                    <Label fx:id="levelValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="Department" GridPane.rowIndex="5" style="-fx-text-fill: white;"/>
                    <Label fx:id="departmentValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="Email" GridPane.rowIndex="6" style="-fx-text-fill: white;"/>
                    <Label fx:id="emailValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="6" style="-fx-text-fill: #d0e4ff;"/>

                    <Label text="Contact" GridPane.rowIndex="7" style="-fx-text-fill: white;"/>
                    <Label fx:id="contactValue" text="-" GridPane.columnIndex="1" GridPane.rowIndex="7" style="-fx-text-fill: #d0e4ff;"/>
                </GridPane>
            </VBox>
        </VBox>
    </center>

</BorderPane>
