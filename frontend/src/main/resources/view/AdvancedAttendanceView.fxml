<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.AdvancedAttendanceViewController"
            prefWidth="1100" prefHeight="760"
            style="-fx-background-color: #0f1b35;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>
            <Label text="📊  Attendance View (Individual &amp; Batch)"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Back Dashboard" onAction="#backToDashboard"
                    style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <HBox spacing="12">
                <VBox spacing="6">
                    <Label text="Mode" style="-fx-text-fill: #a0c4ff;"/>
                    <ComboBox fx:id="modeComboBox" prefWidth="180"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="View Type" style="-fx-text-fill: #a0c4ff;"/>
                    <ComboBox fx:id="viewTypeComboBox" prefWidth="180"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label fx:id="targetLabel" text="Student ID" style="-fx-text-fill: #a0c4ff;"/>
                    <TextField fx:id="targetField" promptText="Enter value"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Actions" style="-fx-text-fill: #a0c4ff;"/>
                    <HBox spacing="8">
                        <Button text="Load Details" onAction="#loadDetails"/>
                        <Button text="Load Summary" onAction="#loadSummary"/>
                    </HBox>
                </VBox>
            </HBox>

            <Label fx:id="statusLabel" textFill="WHITE"/>

            <HBox spacing="12" VBox.vgrow="ALWAYS">
                <VBox spacing="6" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label text="Details Response" style="-fx-text-fill: #a0c4ff;"/>
                    <TextArea fx:id="detailsArea" wrapText="true" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label text="Summary Response" style="-fx-text-fill: #a0c4ff;"/>
                    <TextArea fx:id="summaryArea" wrapText="true" VBox.vgrow="ALWAYS"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
