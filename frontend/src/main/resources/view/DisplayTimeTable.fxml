<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.DisplayTimeTableController"
            prefWidth="820.0"
            prefHeight="620.0"
            style="-fx-background-color: #07111f;">

    <!-- ══════════════════════════  TOP NAV  ══════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="54"
              spacing="0"
              style="-fx-background-color: #07111f; -fx-border-color: #132237; -fx-border-width: 0 0 1 0;">

            <!-- LEFT: Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="54">
                <padding>
                    <Insets top="0" right="20" bottom="0" left="20"/>
                </padding>

                <Label text="🎓" style="-fx-font-size: 22px;"/>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #e8f0fe; -fx-font-size: 14px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #4a7ab5; -fx-font-size: 9px;"/>
                </VBox>
            </HBox>

            <!-- CENTER -->
            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="8">
                <padding>
                    <Insets top="0" right="20" bottom="0" left="20"/>
                </padding>

                <Label text="🗓" style="-fx-font-size: 14px;"/>

                <Label text="TIME TABLE MANAGEMENT"
                       style="-fx-text-fill: #5b9bd5; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 2;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- RIGHT -->
            <HBox alignment="CENTER_RIGHT" spacing="12">
                <padding>
                    <Insets top="0" right="16" bottom="0" left="16"/>
                </padding>

                <StackPane>
                    <Circle radius="14"
                            style="-fx-fill: linear-gradient(to bottom right, #2563eb, #1d4ed8);"/>
                    <Label text="A"
                           style="-fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </StackPane>

                <Label fx:id="adminNameLabel"
                       text="Administrator"
                       style="-fx-text-fill: #c9d8f0; -fx-font-size: 12px;"/>

                <Button text="← Back"
                        onAction="#goBack"
                        style="-fx-background-color: transparent;
                           -fx-text-fill: #4a7ab5;
                           -fx-font-size: 11px;
                           -fx-border-color: #1e3c72;
                           -fx-border-radius: 5;
                           -fx-background-radius: 5;
                           -fx-cursor: hand;
                           -fx-padding: 5 12 5 12;"/>
            </HBox>

        </HBox>
    </top>

    <!-- ══════════════════════════  MAIN CONTENT  ══════════════════════════ -->
    <center>
        <VBox spacing="0">
            <padding><Insets top="24" right="28" bottom="12" left="28"/></padding>

            <!-- Page heading -->
            <VBox spacing="4">
                <Label text="Time Tables"
                       style="-fx-text-fill: #e8f0fe; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                <Label text="Browse, search and open any timetable PDF below."
                       style="-fx-text-fill: #4a7ab5; -fx-font-size: 12px;"/>
            </VBox>

            <Region prefHeight="18"/>

            <!-- Search bar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="🔍  Search by title, department, semester or level…"
                           onKeyReleased="#filterTimeTables"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #0d1e33;
                                  -fx-text-fill: #e0eaf8;
                                  -fx-prompt-text-fill: #304a6a;
                                  -fx-font-size: 12px;
                                  -fx-border-color: #1b3255;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 9 14 9 14;"/>
                <Button text="⟳  Refresh"
                        onAction="#refreshTimeTables"
                        style="-fx-background-color: #0d2040;
                               -fx-text-fill: #5b9bd5;
                               -fx-font-size: 11px;
                               -fx-font-weight: bold;
                               -fx-border-color: #1b3255;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-padding: 9 16 9 16;"/>
            </HBox>

            <Region prefHeight="6"/>

            <!-- Count label -->
            <Label fx:id="totalTimeTablesInfoLabel"
                   text="0 time tables loaded"
                   style="-fx-text-fill: #304a6a; -fx-font-size: 10px;"/>

            <Region prefHeight="10"/>

            <!-- LIST -->
            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                        prefHeight="420">
                <content>
                    <VBox fx:id="timetableListContainer"
                          spacing="6"
                          style="-fx-background-color: transparent;">
                        <padding><Insets top="2" right="2" bottom="10" left="2"/></padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ══════════════════════════  STATUS BAR  ══════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="8"
              prefHeight="30"
              style="-fx-background-color: #050e1a; -fx-border-color: #0d1e33; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="5" right="20" bottom="5" left="20"/></padding>
            <Label text="●" style="-fx-text-fill: #22c55e; -fx-font-size: 8px;"/>
            <Label fx:id="statusLabel"
                   text="Ready"
                   style="-fx-text-fill: #304a6a; -fx-font-size: 10px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime"
                   text="--:--:--"
                   style="-fx-text-fill: #1e3c72; -fx-font-size: 10px;"/>
        </HBox>
    </bottom>

</BorderPane>