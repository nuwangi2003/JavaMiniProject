<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.AdminDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #0f1b35;">

    <!-- ═══════════════════════ TOP NAV BAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">
            <padding><Insets top="0" bottom="0" left="0" right="0"/></padding>

            <!-- Logo / App Name -->
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="🎓" style="-fx-font-size: 26px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Nav Items -->
            <HBox spacing="4" alignment="CENTER">
                <padding><Insets left="16" right="16"/></padding>
                <Button fx:id="navDashboard" text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                <Button fx:id="navUsers" text="Users"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"
                        onAction="#openUsers"/>
                <Button fx:id="navCourses" text="Courses"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"
                        onAction="#openCourses"/>
                <Button fx:id="navNotices" text="Notices"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"
                        onAction="#openNotices"/>
                <Button fx:id="navTimetables" text="Timetables"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"
                        onAction="#openTimetables"/>
            </HBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #1e3c72;"/>

            <!-- User info + logout -->
            <HBox alignment="CENTER" spacing="10">
                <padding><Insets left="16" right="20"/></padding>
                <StackPane>
                    <Circle radius="18" style="-fx-fill: linear-gradient(to bottom right, #28a745, #1e7e34);"/>
                    <Label text="A" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="adminNameLabel" text="Administrator"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Admin" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;"
                    hbarPolicy="NEVER">
            <VBox spacing="28" style="-fx-background-color: #0f1b35;">
                <padding><Insets top="30" bottom="30" left="36" right="36"/></padding>

                <!-- Welcome Banner -->
                <VBox spacing="4">
                    <Label fx:id="welcomeLabel" text="Welcome back, Administrator 👋"
                           style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label fx:id="dateLabel" text="Thursday, March 13, 2026  •  Admin Control Panel"
                           style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- ── STAT CARDS ── -->
                <FlowPane hgap="18" vgap="18" prefWrapLength="1200">

                    <!-- Total Users -->
                    <VBox spacing="8" prefWidth="200" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #1e3c72, #2a5298); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="👥  Total Users" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px;"/>
                        <Label fx:id="totalUsersLabel" text="30"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Across all roles" style="-fx-text-fill: #6a90c8; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Undergraduates -->
                    <VBox spacing="8" prefWidth="200" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #155724, #1e7e34); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="🎓  Undergraduates" style="-fx-text-fill: #a8e6cf; -fx-font-size: 12px;"/>
                        <Label fx:id="totalStudentsLabel" text="20"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Active students" style="-fx-text-fill: #74c69d; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Lecturers -->
                    <VBox spacing="8" prefWidth="200" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #7b2d00, #c0622a); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📚  Lecturers" style="-fx-text-fill: #ffd8b1; -fx-font-size: 12px;"/>
                        <Label fx:id="totalLecturersLabel" text="5"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Faculty members" style="-fx-text-fill: #ffb347; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Technical Officers -->
                    <VBox spacing="8" prefWidth="200" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #4a0072, #7b1fa2); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="🔧  Tech Officers" style="-fx-text-fill: #e1b3ff; -fx-font-size: 12px;"/>
                        <Label fx:id="totalTechLabel" text="4"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Department staff" style="-fx-text-fill: #ce93d8; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Active Courses -->
                    <VBox spacing="8" prefWidth="200" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #0a4a6e, #1565c0); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📋  Courses" style="-fx-text-fill: #90caf9; -fx-font-size: 12px;"/>
                        <Label fx:id="totalCoursesLabel" text="8"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="This semester" style="-fx-text-fill: #64b5f6; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <!-- ── QUICK ACTIONS ── -->
                <VBox spacing="14"
                      style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                    <Label text="Quick Actions"
                           style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Separator style="-fx-background-color: #1e3c72;"/>
                    <FlowPane hgap="12" vgap="12">
                        <Button text="➕  Add User" onAction="#openAddUser" prefHeight="42" prefWidth="170"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📖  Add Course" onAction="#openAddCourses" prefHeight="42" prefWidth="170"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="🔗  Assign Course" onAction="#openAssignCourse" prefHeight="42" prefWidth="170"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📢  Post Notice" onAction="#openAddNotices" prefHeight="42" prefWidth="170"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📅  Add Timetable" onAction="#openTimeAddTimeTables" prefHeight="42" prefWidth="170"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    </FlowPane>
                </VBox>

                <!-- ── RECENT NOTICES ── -->
                <VBox spacing="14"
                      style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="📢  Recent Notices"
                               style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="View All →" onAction="#openNotices"
                                style="-fx-background-color: transparent; -fx-text-fill: #4a90d9; -fx-font-size: 12px; -fx-cursor: hand;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1e3c72;"/>
                    <VBox fx:id="noticesContainer" spacing="10"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ═══════════════════════ STATUS BAR ═══════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>
            <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 10px;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text="13 March 2026"
                   style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>