<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.CourseDisplayController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #08111f;">

    <!-- ═══════════════════════  TOP NAV BAR  ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68" spacing="0"
              style="-fx-background-color: #0b1829;
                     -fx-border-color: #1a3355;
                     -fx-border-width: 0 0 1 0;">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="68">
                <padding><Insets left="28" right="32"/></padding>
                <StackPane>
                    <Circle radius="20"
                            style="-fx-fill: linear-gradient(to bottom right, #2563eb, #1d4ed8);
                                   -fx-effect: dropshadow(gaussian,rgba(37,99,235,0.5),12,0.3,0,0);"/>
                    <Label text="🎓" style="-fx-font-size: 18px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;
                                  -fx-font-family: 'Segoe UI';"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #4a7ab5; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                </VBox>
            </HBox>

            <Rectangle width="1" height="36" style="-fx-fill: #1a3355;"/>

            <!-- Page Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="📘" style="-fx-font-size: 16px; -fx-text-fill: #3b82f6;"/>
                <Label text="Course Display"
                       style="-fx-text-fill: #93c5fd; -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Admin Info -->
            <HBox alignment="CENTER" spacing="12">
                <padding><Insets left="20" right="12"/></padding>
                <StackPane>
                    <Circle radius="20"
                            style="-fx-fill: linear-gradient(to bottom right, #16a34a, #15803d);
                                   -fx-effect: dropshadow(gaussian,rgba(22,163,74,0.4),10,0.3,0,0);"/>
                    <Label text="A"
                           style="-fx-text-fill: white; -fx-font-weight: bold;
                                  -fx-font-size: 14px; -fx-font-family: 'Segoe UI';"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="adminNameLabel" text="Administrator"
                           style="-fx-text-fill: white; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Admin"
                           style="-fx-text-fill: #4a7ab5; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                </VBox>
            </HBox>

            <!-- Back Button -->
            <HBox alignment="CENTER">
                <padding><Insets left="12" right="24"/></padding>
                <Button text="← Back" onAction="#goBack"
                        prefHeight="36" prefWidth="100"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #93c5fd;
                               -fx-font-size: 12px; -fx-font-family: 'Segoe UI';
                               -fx-border-color: #1e3a5f;
                               -fx-border-radius: 6; -fx-border-width: 1;
                               -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════  MAIN CONTENT  ═══════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

            <VBox spacing="0" style="-fx-background-color: #08111f;">
                <padding><Insets top="40" bottom="40" left="60" right="60"/></padding>

                <!-- Page Heading -->
                <VBox spacing="6">
                    <padding><Insets bottom="32"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane>
                            <Rectangle arcWidth="10" arcHeight="10" width="40" height="40"
                                       style="-fx-fill: rgba(37,99,235,0.15);"/>
                            <Label text="📚" style="-fx-font-size: 20px;"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="Course Display"
                                   style="-fx-text-fill: white; -fx-font-size: 26px;
                                          -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <Label text="View and filter all available courses by name, level, and semester"
                                   style="-fx-text-fill: #4a7ab5; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ─── Main Card ─── -->
                <VBox spacing="0"
                      style="-fx-background-color: #0d1e36;
                             -fx-background-radius: 16;
                             -fx-border-color: #1a3355;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.6),28,0,0,8);">

                    <!-- Card Header -->
                    <HBox alignment="CENTER_LEFT" spacing="14"
                          style="-fx-background-color: linear-gradient(to right, #0f2444, #0d1e36);
                                 -fx-background-radius: 16 16 0 0;
                                 -fx-border-color: transparent transparent #1a3355 transparent;
                                 -fx-border-width: 0 0 1 0;">
                        <padding><Insets top="20" bottom="20" left="28" right="28"/></padding>

                        <StackPane>
                            <Circle radius="18"
                                    style="-fx-fill: rgba(37,99,235,0.2);"/>
                            <Label text="📘" style="-fx-font-size: 16px;"/>
                        </StackPane>

                        <VBox spacing="3">
                            <Label text="Course Records"
                                   style="-fx-text-fill: white; -fx-font-size: 15px;
                                          -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <Label text="Browse and filter course information"
                                   style="-fx-text-fill: #4a7ab5; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"/>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label text="Use filters to narrow results"
                               style="-fx-text-fill: #2563eb; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                    </HBox>

                    <!-- Card Body -->
                    <VBox spacing="24">
                        <padding><Insets top="28" bottom="28" left="28" right="28"/></padding>

                        <!-- Filters -->
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Search Course"
                                       style="-fx-text-fill: #93c5fd; -fx-font-size: 12px;
                                              -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                <TextField fx:id="searchField"
                                           promptText="Search by course name or code..."
                                           prefHeight="44"
                                           style="-fx-background-color: #091527;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #1e3a5f;
                                                  -fx-border-radius: 10;
                                                  -fx-border-width: 1.5;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: #4a7ab5;
                                                  -fx-font-size: 13px;
                                                  -fx-font-family: 'Segoe UI';"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Level"
                                       style="-fx-text-fill: #93c5fd; -fx-font-size: 12px;
                                              -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                <ComboBox fx:id="levelFilter"
                                          promptText="All Levels"
                                          prefWidth="150"
                                          prefHeight="44"
                                          style="-fx-background-color: #091527;
                                                 -fx-background-radius: 10;
                                                 -fx-border-color: #1e3a5f;
                                                 -fx-border-radius: 10;
                                                 -fx-border-width: 1.5;
                                                 -fx-text-fill: white;
                                                 -fx-font-size: 13px;
                                                 -fx-font-family: 'Segoe UI';"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Semester"
                                       style="-fx-text-fill: #93c5fd; -fx-font-size: 12px;
                                              -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                <ComboBox fx:id="semesterFilter"
                                          promptText="All Semesters"
                                          prefWidth="160"
                                          prefHeight="44"
                                          style="-fx-background-color: #091527;
                                                 -fx-background-radius: 10;
                                                 -fx-border-color: #1e3a5f;
                                                 -fx-border-radius: 10;
                                                 -fx-border-width: 1.5;
                                                 -fx-text-fill: white;
                                                 -fx-font-size: 13px;
                                                 -fx-font-family: 'Segoe UI';"/>
                            </VBox>

                            <VBox spacing="8">
                                <Label text="Action"
                                       style="-fx-text-fill: transparent; -fx-font-size: 12px;"/>
                                <Button text="⟳ Refresh"
                                        onAction="#refreshCourses"
                                        prefHeight="44" prefWidth="130"
                                        style="-fx-background-color: linear-gradient(to right, #1d4ed8, #2563eb);
                                               -fx-text-fill: white;
                                               -fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                               -fx-font-weight: bold;
                                               -fx-background-radius: 10;
                                               -fx-cursor: hand;
                                               -fx-effect: dropshadow(gaussian,rgba(37,99,235,0.45),14,0.3,0,3);"/>
                            </VBox>
                        </HBox>

                        <!-- Divider -->
                        <HBox>
                            <Region prefHeight="1"
                                    style="-fx-background-color: #1a3355;"
                                    HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Table -->
                        <VBox spacing="10">
                            <Label text="Available Courses"
                                   style="-fx-text-fill: #93c5fd; -fx-font-size: 12px;
                                          -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

                            <TableView fx:id="courseTable"
                                       prefHeight="420"
                                       columnResizePolicy="CONSTRAINED_RESIZE_POLICY"
                                       style="-fx-background-color: #091527;
                                              -fx-control-inner-background: #091527;
                                              -fx-background-radius: 12;
                                              -fx-border-radius: 12;
                                              -fx-border-color: #1a3355;
                                              -fx-border-width: 1.2;
                                              -fx-table-cell-border-color: #13243d;
                                              -fx-padding: 6;">

                                <columns>
                                    <TableColumn fx:id="colCourseId" text="Course ID"/>
                                    <TableColumn fx:id="colCourseCode" text="Course Code"/>
                                    <TableColumn fx:id="colName" text="Course Name"/>
                                    <TableColumn fx:id="colCredit" text="Credit"/>
                                    <TableColumn fx:id="colLevel" text="Level"/>
                                    <TableColumn fx:id="colSemester" text="Semester"/>
                                    <TableColumn fx:id="colDepartmentId" text="Department"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <!-- Status -->
                        <HBox alignment="CENTER_LEFT" spacing="8" minHeight="28">
                            <Label fx:id="statusLabel" text="Loading courses..."
                                   style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                          -fx-font-weight: bold; -fx-text-fill: #93c5fd;"
                                   visible="true" managed="true" wrapText="true"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Info Strip -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <padding><Insets top="20"/></padding>
                    <Label text="ℹ"
                           style="-fx-text-fill: #2563eb; -fx-font-size: 13px;"/>
                    <Label text="Use the search field and filters to quickly find courses by name, academic level, or semester."
                           style="-fx-text-fill: #334d6e; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ═══════════════════════  BOTTOM STATUS BAR  ═══════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="36"
              style="-fx-background-color: #0b1829;
                     -fx-border-color: #1a3355;
                     -fx-border-width: 1 0 0 0;">
            <padding><Insets left="24" right="24"/></padding>
            <Circle radius="5"
                    style="-fx-fill: #16a34a;
                           -fx-effect: dropshadow(gaussian,rgba(22,163,74,0.7),8,0.4,0,0);"/>
            <Label text="System Online"
                   style="-fx-text-fill: #16a34a; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
            <Label text="•"
                   style="-fx-text-fill: #1a3355; -fx-font-size: 10px;"/>
            <Label text="Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #334d6e; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text=""
                   style="-fx-text-fill: #334d6e; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
        </HBox>
    </bottom>
</BorderPane>