<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.image.ImageView?>
<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.student.StudentDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #0f1b35;">

    <!-- ═══════════════════════ TOP NAV BAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="🎓" style="-fx-font-size: 26px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="4" alignment="CENTER">
                <padding><Insets left="16" right="16"/></padding>
                <Button text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                <Button text="My Courses" onAction="#openCourses"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Attendance" onAction="#openAttendance"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Medicals" onAction="#openMedical"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Grades &amp; GPA" onAction="#openGrades"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Timetable" onAction="#openTimetable"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Notices" onAction="#openNotices"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="My Endpoints" onAction="#openMyAcademicEndpoints"
                    style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <Separator orientation="VERTICAL"/>

            <HBox alignment="CENTER" spacing="10">
                <padding><Insets left="16" right="20"/></padding>
                <StackPane fx:id="profileContainer">

                    <Circle fx:id="profileCircle"
                            radius="18"
                            style="-fx-fill: linear-gradient(to bottom right, #0a4a6e, #1565c0);"/>

                    <ImageView fx:id="profileImage"
                               fitWidth="36"
                               fitHeight="36"
                               preserveRatio="false"
                               visible="false"/>

                    <Label fx:id="profileInitial"
                           text="S"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="studentNameLabel" text="Student Name"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label fx:id="studentIdLabel" text="Reg No: —"
                           style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
                <Button text="My Profile" onAction="#openProfile"
                        style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER">
            <VBox spacing="28" style="-fx-background-color: #0f1b35;">
                <padding><Insets top="30" bottom="30" left="36" right="36"/></padding>

                <VBox spacing="4">
                    <Label fx:id="welcomeLabel" text="Welcome back! 👋"
                           style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label fx:id="dateLabel" text="Thursday, March 13, 2026  •  Undergraduate Portal"
                           style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Stat Cards -->
                <FlowPane hgap="18" vgap="18" prefWrapLength="1200">

                    <!-- Overall Attendance -->
                    <VBox spacing="8" prefWidth="215" prefHeight="120"
                          style="-fx-background-color: linear-gradient(to bottom right, #0a4a6e, #1565c0); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📋  Overall Attendance" style="-fx-text-fill: #90caf9; -fx-font-size: 12px;"/>
                        <Label fx:id="overallAttendanceLabel" text="—%"
                               style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                        <Label text="Across all modules" style="-fx-text-fill: #64b5f6; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- SGPA -->
                    <VBox spacing="8" prefWidth="215" prefHeight="120"
                          style="-fx-background-color: linear-gradient(to bottom right, #155724, #1e7e34); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📊  Current SGPA" style="-fx-text-fill: #a8e6cf; -fx-font-size: 12px;"/>
                        <Label fx:id="sgpaLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                        <Label text="This semester" style="-fx-text-fill: #74c69d; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- CGPA -->
                    <VBox spacing="8" prefWidth="215" prefHeight="120"
                          style="-fx-background-color: linear-gradient(to bottom right, #1e3c72, #2a5298); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="🏆  Cumulative CGPA" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px;"/>
                        <Label fx:id="cgpaLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                        <Label text="Overall GPA" style="-fx-text-fill: #64b5f6; -fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Enrolled Courses -->
                    <VBox spacing="8" prefWidth="215" prefHeight="120"
                          style="-fx-background-color: linear-gradient(to bottom right, #7b2d00, #c0622a); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📚  Enrolled Courses" style="-fx-text-fill: #ffd8b1; -fx-font-size: 12px;"/>
                        <Label fx:id="enrolledCoursesLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                        <Label text="This semester" style="-fx-text-fill: #ffb347; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <!-- Eligibility Alert Row -->
                <HBox fx:id="eligibilityAlertBox" spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: #162040; -fx-background-radius: 10; -fx-border-color: #ffc107; -fx-border-radius: 10; -fx-border-width: 1;">

                    <!-- My Academic Info Section -->
                    <VBox spacing="12"
                          style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14;">

                        <padding>
                            <Insets top="20" bottom="20" left="20" right="20"/>
                        </padding>

                        <Label text="🎓  My Academic Info"
                               style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <FlowPane hgap="12" vgap="12">

                            <Button text="📝  My Final Marks" onAction="#openStudentFinalMarks"
                                    prefHeight="42" prefWidth="180"
                                    style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                            <Button text="📊  My Grades" onAction="#openStudentGrades"
                                    prefHeight="42" prefWidth="180"
                                    style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                            <Button text="✅  My Eligibility" onAction="#openEligibility"
                                    prefHeight="42" prefWidth="180"
                                    style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>

                        </FlowPane>

                    </VBox>                    

                    <padding><Insets top="14" bottom="14" left="18" right="18"/></padding>
                    <Label text="⚠️" style="-fx-font-size: 18px;"/>
                    <VBox spacing="2">
                        <Label text="Exam Eligibility Status"
                               style="-fx-text-fill: #ffc107; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <Label fx:id="eligibilityStatusLabel" text="Checking eligibility..."
                               style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="View Details →" onAction="#openEligibility"
                            style="-fx-background-color: #ffc107; -fx-text-fill: #0a1628; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Two-column lower section -->
                <HBox spacing="18" alignment="TOP_LEFT">

                    <!-- My Courses This Semester -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                        <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📖  My Courses"
                                   style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="View All →" onAction="#openCourses"
                                    style="-fx-background-color: transparent; -fx-text-fill: #4a90d9; -fx-font-size: 12px; -fx-cursor: hand;"/>
                        </HBox>
                        <Separator style="-fx-background-color: #1e3c72;"/>
                        <!-- Column headers -->
                        <HBox spacing="0" style="-fx-background-color: #1e3c72; -fx-background-radius: 8;">
                            <padding><Insets top="8" bottom="8" left="12" right="12"/></padding>
                            <Label text="Code" prefWidth="110" style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label text="Course Name" prefWidth="200" style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label text="Credits" prefWidth="70" style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label text="Grade" prefWidth="70" style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </HBox>
                        <VBox fx:id="coursesContainer" spacing="4"/>
                    </VBox>

                    <!-- Recent Notices -->
                    <VBox spacing="14" prefWidth="340"
                          style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                        <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📢  Notices"
                                   style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="All →" onAction="#openNotices"
                                    style="-fx-background-color: transparent; -fx-text-fill: #4a90d9; -fx-font-size: 12px; -fx-cursor: hand;"/>
                        </HBox>
                        <Separator style="-fx-background-color: #1e3c72;"/>
                        <VBox fx:id="noticesContainer" spacing="10"/>
                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Status Bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>
            <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 10px;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text="13 March 2026" style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>