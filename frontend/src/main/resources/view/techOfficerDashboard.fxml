<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.tech_officer.TechOfficerDashboardController"
            prefWidth="1200" prefHeight="750"
            style="-fx-background-color: #0f1b35;">

    <!-- ═══════════════════════ TOP NAV BAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="🎓" style="-fx-font-size: 26px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal" style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="4" alignment="CENTER">
                <padding><Insets left="16" right="16"/></padding>
                <Button text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                <Button text="Attendance" onAction="#openAttendance"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Medical Records" onAction="#openMedical"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Timetables" onAction="#openTimetables"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Notices" onAction="#openNotices"
                        style="-fx-background-color: transparent; -fx-text-fill: #a0b8e0; -fx-font-size: 13px; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>

            <Separator orientation="VERTICAL"/>

            <HBox alignment="CENTER" spacing="10">
                <padding><Insets left="16" right="20"/></padding>
                <StackPane>
                    <Circle radius="18" style="-fx-fill: linear-gradient(to bottom right, #4a0072, #7b1fa2);"/>
                    <Label text="T" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="techNameLabel" text="Tech Officer"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Technical Officer" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
                <Button text="My Profile" onAction="#openProfile"
                        style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════ MAIN CONTENT ═══════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" hbarPolicy="NEVER">
            <VBox spacing="28" style="-fx-background-color: #0f1b35;">
                <padding><Insets top="30" bottom="30" left="36" right="36"/></padding>

                <VBox spacing="4">
                    <Label fx:id="welcomeLabel" text="Welcome, Tech Officer 👋"
                           style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label fx:id="dateLabel" text="Thursday, March 13, 2026  •  Technical Officer Panel"
                           style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Stat Cards -->
                <FlowPane hgap="18" vgap="18" prefWrapLength="1200">

                    <VBox spacing="8" prefWidth="220" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #4a0072, #7b1fa2); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="👤  Total Students" style="-fx-text-fill: #e1b3ff; -fx-font-size: 12px;"/>
                        <Label fx:id="totalStudentsLabel" text="20"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Active undergrads" style="-fx-text-fill: #ce93d8; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="220" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #0a4a6e, #1565c0); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="📋  Attendance Sessions" style="-fx-text-fill: #90caf9; -fx-font-size: 12px;"/>
                        <Label fx:id="attendanceSessionsLabel" text="15"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Per subject" style="-fx-text-fill: #64b5f6; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="220" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #155724, #1e7e34); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="🏥  Medical Records" style="-fx-text-fill: #a8e6cf; -fx-font-size: 12px;"/>
                        <Label fx:id="medicalRecordsLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Submitted medicals" style="-fx-text-fill: #74c69d; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="220" prefHeight="110"
                          style="-fx-background-color: linear-gradient(to bottom right, #7b2d00, #c0622a); -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box,rgba(0,0,0,0.35),12,0,0,4);">
                        <padding><Insets top="20" bottom="20" left="22" right="22"/></padding>
                        <Label text="⚠️  Pending Approvals" style="-fx-text-fill: #ffd8b1; -fx-font-size: 12px;"/>
                        <Label fx:id="pendingApprovalsLabel" text="—"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Medical approvals" style="-fx-text-fill: #ffb347; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <!-- Quick Actions -->
                <VBox spacing="14"
                      style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                    <Label text="Quick Actions"
                           style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Separator style="-fx-background-color: #1e3c72;"/>
                    <FlowPane hgap="12" vgap="12">
                        <Button text="✅  Mark Attendance" onAction="#openMarkAttendance" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📋  View Attendance" onAction="#openAttendance" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📊  Advanced Attendance View" onAction="#openAdvancedAttendanceView" prefHeight="42" prefWidth="220"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="🏥  Add Medical" onAction="#openAddMedical" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="✔️  Approve Medical" onAction="#openMedical" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <Button text="📅  Timetable" onAction="#openTimetables" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </FlowPane>
                </VBox>

                <!-- Attendance Summary -->
                <VBox spacing="14"
                      style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="📊  Attendance Overview (Batch)"
                               style="-fx-text-fill: #a0c4ff; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Full Report →" onAction="#openAttendance"
                                style="-fx-background-color: transparent; -fx-text-fill: #4a90d9; -fx-font-size: 12px; -fx-cursor: hand;"/>
                    </HBox>
                    <Separator style="-fx-background-color: #1e3c72;"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Batch" style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                        <TextField fx:id="batchEligibilityField" promptText="e.g. 2023" prefWidth="140"
                                   style="-fx-background-color: #0f1b35; -fx-text-fill: white; -fx-border-color: #1e3c72;"/>
                        <Label text="View" style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                        <ComboBox fx:id="viewTypeEligibilityCombo" prefWidth="150"
                                  style="-fx-background-color: #0f1b35; -fx-border-color: #1e3c72;"/>
                        <Button text="Refresh" onAction="#refreshAttendanceEligibilityReport" prefHeight="32"
                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Legend row -->
                    <HBox spacing="24" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 14px;"/>
                            <Label text="Above 80%" style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #ffc107; -fx-font-size: 14px;"/>
                            <Label text="Exactly 80%" style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #c0392b; -fx-font-size: 14px;"/>
                            <Label text="Below 80%" style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="🏥" style="-fx-font-size: 12px;"/>
                            <Label text="With Medical" style="-fx-text-fill: #a0b8e0; -fx-font-size: 12px;"/>
                        </HBox>
                    </HBox>

                    <VBox fx:id="attendanceSummaryContainer" spacing="8"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="8" bottom="8" left="24" right="24"/></padding>
            <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 10px;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text="13 March 2026" style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>