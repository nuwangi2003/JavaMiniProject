<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.DisplayNoticeController"
            prefWidth="1000.0"
            prefHeight="600.0"
            style="-fx-background-color: #0f1b35;">

    <!-- TOP -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="0"
              prefHeight="52.0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 1 0;">

            <!-- Left logo section -->
            <HBox alignment="CENTER_LEFT"
                  spacing="10"
                  prefHeight="52.0"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding>
                    <Insets top="10" right="18" bottom="10" left="18"/>
                </padding>
                <children>
                    <Label text="🎓" style="-fx-font-size: 20px;"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <children>
                            <Label text="FoT Portal"
                                   style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                            <Label text="Faculty of Technology"
                                   style="-fx-text-fill: #c7d8f3; -fx-font-size: 9px;"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Center title -->
            <HBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets top="0" right="14" bottom="0" left="14"/>
                </padding>
                <children>
                    <Label text="📢" style="-fx-font-size: 14px;"/>
                    <Label text="Notice Management"
                           style="-fx-text-fill: #a0c4ff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </children>
            </HBox>

            <Separator orientation="VERTICAL"/>

            <!-- Right user section -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <padding>
                    <Insets top="0" right="16" bottom="0" left="16"/>
                </padding>
                <children>
                    <StackPane>
                        <children>
                            <Circle radius="15"
                                    style="-fx-fill: linear-gradient(to bottom right, #28a745, #1e7e34);"/>
                            <Label text="A"
                                   style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </children>
                    </StackPane>

                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <children>
                            <Label fx:id="adminNameLabel"
                                   text="Administrator"
                                   style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <Label text="Admin"
                                   style="-fx-text-fill: #a0b8e0; -fx-font-size: 9px;"/>
                        </children>
                    </VBox>

                    <Button text="← Back"
                            onAction="#goBack"
                            style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </children>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="14" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16" right="18" bottom="16" left="18"/>
            </padding>

            <children>
                <!-- Page heading -->
                <VBox spacing="3">
                    <children>
                        <Label text="Notice Management"
                               style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        <Label text="View all notices and inspect selected notice details."
                               style="-fx-text-fill: #8ea9d6; -fx-font-size: 12px;"/>
                    </children>
                </VBox>

                <!-- Search / Action row -->
                <HBox spacing="12" alignment="BOTTOM_LEFT">
                    <children>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Search by Title"
                                       style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                <TextField fx:id="searchField"
                                           promptText="Type notice title..."
                                           onKeyReleased="#filterNotices"
                                           style="-fx-background-color: #162040; -fx-text-fill: white; -fx-prompt-text-fill: #6a86b8; -fx-font-size: 12px; -fx-border-color: #2a4a7f; -fx-border-radius: 7; -fx-background-radius: 7;"/>
                            </children>
                        </VBox>

                        <VBox spacing="5">
                            <children>
                                <Label text="Actions"
                                       style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                <Button text="Refresh"
                                        onAction="#refreshNotices"
                                        style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 7;"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Main section -->
                <HBox spacing="14" VBox.vgrow="ALWAYS">
                    <children>

                        <!-- LEFT PANEL -->
                        <VBox spacing="0"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #162040; -fx-background-radius: 12; -fx-border-color: #1e3c72; -fx-border-radius: 12; -fx-border-width: 1;">
                            <children>

                                <!-- Left header -->
                                <HBox alignment="CENTER_LEFT"
                                      spacing="8"
                                      style="-fx-background-color: linear-gradient(to right, #1e3c72, #1a2d5a); -fx-background-radius: 12 12 0 0;">
                                    <padding>
                                        <Insets top="12" right="16" bottom="12" left="16"/>
                                    </padding>
                                    <children>
                                        <VBox spacing="1">
                                            <children>
                                                <Label text="Notices List"
                                                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                <Label fx:id="totalNoticesInfoLabel"
                                                       text="0 notices loaded"
                                                       style="-fx-text-fill: #9cb6e0; -fx-font-size: 10px;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Scroll area -->
                                <ScrollPane fx:id="noticeScrollPane"
                                            fitToWidth="true"
                                            VBox.vgrow="ALWAYS"
                                            hbarPolicy="NEVER"
                                            style="-fx-background: transparent; -fx-background-color: transparent;">
                                    <content>
                                        <VBox fx:id="noticeListContainer"
                                              spacing="10"
                                              style="-fx-background-color: transparent;">
                                            <padding>
                                                <Insets top="14" right="14" bottom="14" left="14"/>
                                            </padding>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <!-- RIGHT PANEL -->
                        <VBox prefWidth="260"
                              minWidth="260"
                              maxWidth="260"
                              spacing="0"
                              style="-fx-background-color: #162040; -fx-background-radius: 12; -fx-border-color: #1e3c72; -fx-border-radius: 12; -fx-border-width: 1;">
                            <children>

                                <!-- Right header -->
                                <HBox alignment="CENTER_LEFT"
                                      spacing="8"
                                      style="-fx-background-color: linear-gradient(to right, #1e3c72, #1a2d5a); -fx-background-radius: 12 12 0 0;">
                                    <padding>
                                        <Insets top="12" right="16" bottom="12" left="16"/>
                                    </padding>
                                    <children>
                                        <VBox spacing="1">
                                            <children>
                                                <Label text="Notice Details"
                                                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                <Label text="Click a card to view"
                                                       style="-fx-text-fill: #9cb6e0; -fx-font-size: 10px;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="14" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets top="18" right="16" bottom="18" left="16"/>
                                    </padding>

                                    <children>
                                        <StackPane>
                                            <children>
                                                <Circle radius="30"
                                                        style="-fx-fill: linear-gradient(to bottom right, #2a5298, #1e3c72);"/>
                                                <Label text="N"
                                                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                            </children>
                                        </StackPane>

                                        <VBox spacing="4" alignment="CENTER">
                                            <children>
                                                <Label fx:id="detailTitleLabel"
                                                       text="Select a notice"
                                                       wrapText="true"
                                                       maxWidth="220"
                                                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-alignment: center;"/>
                                                <Label text="Notice"
                                                       style="-fx-background-color: #243b6b; -fx-text-fill: #a0c4ff; -fx-padding: 3 10 3 10; -fx-background-radius: 18; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                            </children>
                                        </VBox>

                                        <Region prefHeight="1"
                                                style="-fx-background-color: #1e3c72;"/>

                                        <VBox spacing="12">
                                            <children>
                                                <VBox spacing="3">
                                                    <children>
                                                        <Label text="Notice ID"
                                                               style="-fx-text-fill: #8ea9d6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailIdLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="3">
                                                    <children>
                                                        <Label text="Description"
                                                               style="-fx-text-fill: #8ea9d6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailDescriptionLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="3">
                                                    <children>
                                                        <Label text="Created By"
                                                               style="-fx-text-fill: #8ea9d6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailCreatedByLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="3">
                                                    <children>
                                                        <Label text="Created At"
                                                               style="-fx-text-fill: #8ea9d6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailCreatedAtLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: white; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="3">
                                                    <children>
                                                        <Label text="PDF File"
                                                               style="-fx-text-fill: #8ea9d6; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                                        <Hyperlink fx:id="detailPdfLink"
                                                                   text="Open attached PDF"
                                                                   onAction="#openSelectedNoticePdf"
                                                                   wrapText="true"
                                                                   style="-fx-text-fill: #7db4ff; -fx-font-size: 12px;"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <Region VBox.vgrow="ALWAYS"/>

                                        <Button text="Open PDF in Computer"
                                                onAction="#openSelectedNoticePdf"
                                                maxWidth="Infinity"
                                                style="-fx-background-color: linear-gradient(to right, #1e5c2a, #28a745); -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 7;"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              prefHeight="32"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="6" right="18" bottom="6" left="18"/>
            </padding>
            <children>
                <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 9px;"/>
                <Label fx:id="statusLabel"
                       text="Ready"
                       style="-fx-text-fill: #87a2ce; -fx-font-size: 10px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusBarTime"
                       text="Time"
                       style="-fx-text-fill: #87a2ce; -fx-font-size: 10px;"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>