<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<?import javafx.scene.control.Separator?>
<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.DisplayNoticeController"
            prefWidth="1180.0"
            prefHeight="720.0"
            style="-fx-background-color: #0f1b35;">

    <!-- TOP -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding>
                    <Insets left="24" right="24"/>
                </padding>
                <children>
                    <Label text="🎓" style="-fx-font-size: 26px;"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <children>
                            <Label text="FoT Portal"
                                   style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                            <Label text="Faculty of Technology"
                                   style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="8">
                <padding>
                    <Insets left="16" right="16"/>
                </padding>
                <children>
                    <Label text="📢" style="-fx-font-size: 16px;"/>
                    <Label text="Notice Management"
                           style="-fx-text-fill: #a0c4ff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </children>
            </HBox>

            <Separator orientation="VERTICAL"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="16" right="20"/>
                </padding>
                <children>
                    <StackPane>
                        <children>
                            <Circle radius="18" style="-fx-fill: linear-gradient(to bottom right, #28a745, #1e7e34);"/>
                            <Label text="A" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        </children>
                    </StackPane>

                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <children>
                            <Label fx:id="adminNameLabel" text="Administrator"
                                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <Label text="Admin"
                                   style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                        </children>
                    </VBox>

                    <Button text="← Back"
                            onAction="#goBack"
                            style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </children>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="28.0" right="32.0" bottom="28.0" left="32.0"/>
            </padding>

            <children>
                <!-- Header -->
                <VBox spacing="5">
                    <children>
                        <Label text="Notice Management"
                               style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                        <Label text="View all notices and inspect selected notice details."
                               style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
                    </children>
                </VBox>

                <!-- Search row -->
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Search by Title"
                                       style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <TextField fx:id="searchField"
                                           promptText="Type notice title..."
                                           onKeyReleased="#filterNotices"
                                           style="-fx-background-color: #162040; -fx-text-fill: white; -fx-prompt-text-fill: #3a5a8a; -fx-font-size: 13px; -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                            </children>
                        </VBox>

                        <VBox spacing="6">
                            <children>
                                <Label text="Actions"
                                       style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                                <HBox spacing="10">
                                    <children>
                                        <Button text="Refresh"
                                                onAction="#refreshNotices"
                                                style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Main content -->
                <HBox spacing="22" VBox.vgrow="ALWAYS">
                    <children>

                        <!-- LEFT CARD -->
                        <VBox spacing="0"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">

                            <children>
                                <HBox alignment="CENTER_LEFT"
                                      spacing="10"
                                      style="-fx-background-color: linear-gradient(to right, #1e3c72, #1a2d5a); -fx-background-radius: 14 14 0 0;">
                                    <padding>
                                        <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
                                    </padding>
                                    <children>
                                        <VBox spacing="1">
                                            <children>
                                                <Label text="Notices List"
                                                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label fx:id="totalNoticesInfoLabel"
                                                       text="0 notices loaded"
                                                       style="-fx-text-fill: #6a90c8; -fx-font-size: 11px;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="0" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0"/>
                                    </padding>

                                    <children>
                                        <ScrollPane fx:id="noticeScrollPane"
                                                    fitToWidth="true"
                                                    VBox.vgrow="ALWAYS"
                                                    style="-fx-background-color: transparent;">
                                            <content>
                                                <VBox fx:id="noticeListContainer"
                                                      spacing="14"
                                                      style="-fx-background-color: transparent;"/>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- RIGHT CARD -->
                        <VBox prefWidth="340.0"
                              spacing="0"
                              style="-fx-background-color: #162040; -fx-background-radius: 14; -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">

                            <children>
                                <HBox alignment="CENTER_LEFT"
                                      spacing="10"
                                      style="-fx-background-color: linear-gradient(to right, #1e3c72, #1a2d5a); -fx-background-radius: 14 14 0 0;">
                                    <padding>
                                        <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
                                    </padding>
                                    <children>
                                        <VBox spacing="1">
                                            <children>
                                                <Label text="Notice Details"
                                                       style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="Click a notice card to view details"
                                                       style="-fx-text-fill: #6a90c8; -fx-font-size: 11px;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="18">
                                    <padding>
                                        <Insets top="24.0" right="22.0" bottom="24.0" left="22.0"/>
                                    </padding>

                                    <children>
                                        <StackPane>
                                            <children>
                                                <Circle radius="36.0"
                                                        style="-fx-fill: linear-gradient(to bottom right, #2a5298, #1e3c72);"/>
                                                <Label text="N"
                                                       style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                                            </children>
                                        </StackPane>

                                        <VBox spacing="4" alignment="CENTER">
                                            <children>
                                                <Label fx:id="detailTitleLabel"
                                                       text="Select a notice"
                                                       wrapText="true"
                                                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                                                <Label text="Notice"
                                                       style="-fx-background-color: #243b6b; -fx-text-fill: #a0c4ff; -fx-padding: 4 10 4 10; -fx-background-radius: 20; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                            </children>
                                        </VBox>

                                        <!-- horizontal line -->
                                        <Region prefHeight="1.0"
                                                style="-fx-background-color: #1e3c72;"/>

                                        <VBox spacing="14">
                                            <children>
                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Notice ID"
                                                               style="-fx-text-fill: #6a90c8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailIdLabel"
                                                               text="—"
                                                               style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Description"
                                                               style="-fx-text-fill: #6a90c8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailDescriptionLabel"
                                                               text="—"
                                                               wrapText="true"
                                                               style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Created By"
                                                               style="-fx-text-fill: #6a90c8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailCreatedByLabel"
                                                               text="—"
                                                               style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="Created At"
                                                               style="-fx-text-fill: #6a90c8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Label fx:id="detailCreatedAtLabel"
                                                               text="—"
                                                               style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                                    </children>
                                                </VBox>

                                                <VBox spacing="4">
                                                    <children>
                                                        <Label text="PDF File"
                                                               style="-fx-text-fill: #6a90c8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                                                        <Hyperlink fx:id="detailPdfLink"
                                                                   text="Open attached PDF"
                                                                   onAction="#openSelectedNoticePdf"
                                                                   style="-fx-text-fill: #7db4ff; -fx-font-size: 13px;"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <Button text="Open PDF in Computer"
                                                onAction="#openSelectedNoticePdf"
                                                maxWidth="9999.0"
                                                style="-fx-background-color: linear-gradient(to right, #1e5c2a, #28a745); -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT"
              spacing="16"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8.0" bottom="8.0" left="24.0" right="24.0"/>
            </padding>

            <children>
                <Label text="●" style="-fx-text-fill: #28a745; -fx-font-size: 10px;"/>
                <Label fx:id="statusLabel"
                       text="Ready"
                       style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusBarTime"
                       text="Time"
                       style="-fx-text-fill: #4a6a9a; -fx-font-size: 11px;"/>
            </children>
        </HBox>
    </bottom>

</BorderPane>