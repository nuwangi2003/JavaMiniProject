<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);" xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.controller.tech_officer.TechOfficerDashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);                      -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12">
                <padding>
                    <Insets left="24" right="24" />
                </padding>

                <StackPane prefHeight="63.0" prefWidth="72.0" style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label style="-fx-font-size: 22px;" text="🎓" />
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label prefHeight="27.0" prefWidth="170.0" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="FoT Portal" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;" text="Technical Officer Panel" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets left="16" right="16" />
                </padding>
   
                <Button style="-fx-background-color: rgba(255,255,255,0.22);                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-font-weight: bold;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Dashboard" />

                <Button onAction="#openTimetables" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Timetables" />

                <Button onAction="#openNotices" style="-fx-background-color: transparent;                                -fx-text-fill: white;                                -fx-font-size: 13px;                                -fx-background-radius: 10;                                -fx-padding: 8 18 8 18;                                -fx-cursor: hand;" text="Notices" />
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="10" right="20" />
                </padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: white;" />

                    <ImageView fx:id="dashboardProfileImage" fitHeight="36" fitWidth="36" preserveRatio="false" visible="false" />

                    <Label fx:id="dashboardProfileInitial" style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;" text="T" />
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="techNameLabel" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Tech Officer" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;" text="Technical Officer" />
                </VBox>

                <Button onAction="#openProfile" style="-fx-background-color: rgba(255,255,255,0.18);                                -fx-text-fill: white;                                -fx-font-size: 12px;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-cursor: hand;                                -fx-border-color: rgba(255,255,255,0.22);                                -fx-border-radius: 8;                                -fx-border-width: 1;" text="My Profile" />

                <Button onAction="#logout" style="-fx-background-color: white;                                -fx-text-fill: #e85d5d;                                -fx-font-size: 12px;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-cursor: hand;" text="Logout" />
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="26" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="28" left="34" right="34" top="28" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="18" style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff);                              -fx-background-radius: 18;                              -fx-border-color: #d7e7f8;                              -fx-border-radius: 18;                              -fx-border-width: 1;                              -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">
                    <padding>
                        <Insets bottom="22" left="24" right="24" top="22" />
                    </padding>

                    <StackPane prefHeight="58" prefWidth="58" style="-fx-background-color: linear-gradient(to bottom right, #8e5fd2, #b083ea);                                       -fx-background-radius: 29;">

                        <ImageView fx:id="welcomeProfileImage" fitHeight="58" fitWidth="58" preserveRatio="false" visible="false" />

                        <Label fx:id="welcomeProfileInitial" style="-fx-font-size: 22px;" text="🛠" />
                    </StackPane>

                    <VBox spacing="5">
                        <Label fx:id="welcomeLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 27px; -fx-font-weight: bold;" text="Welcome, Tech Officer 👋" />
                        <Label fx:id="dateLabel" style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;" text="Thursday, March 13, 2026  •  Technical Officer Panel" />
                    </VBox>
                </HBox>

                <FlowPane hgap="18" prefWrapLength="1100" vgap="18">

                    <VBox prefHeight="122" prefWidth="220" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #faf5ff, #fdfaff);                                  -fx-background-radius: 16;                                  -fx-border-color: #ead8ff;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(163,101,229,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #8e5fd2; -fx-font-size: 12px; -fx-font-weight: bold;" text="👤  Total Students" />
                        <Label fx:id="totalStudentsLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="20" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Active undergrads" />
                    </VBox>

                    <VBox prefHeight="122" prefWidth="220" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #eef8ff, #f8fbff);                                  -fx-background-radius: 16;                                  -fx-border-color: #d8e7f7;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.16), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #468ed0; -fx-font-size: 12px; -fx-font-weight: bold;" text="📋  Attendance Sessions" />
                        <Label fx:id="attendanceSessionsLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="15" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Per subject" />
                    </VBox>

                    <VBox prefHeight="122" prefWidth="220" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #effcf4, #f7fff9);                                  -fx-background-radius: 16;                                  -fx-border-color: #cfead7;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(109,186,130,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #35a053; -fx-font-size: 12px; -fx-font-weight: bold;" text="🏥  Medical Records" />
                        <Label fx:id="medicalRecordsLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="—" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Submitted medicals" />
                    </VBox>

                    <VBox prefHeight="122" prefWidth="220" spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #fff8ef, #fffdf8);                                  -fx-background-radius: 16;                                  -fx-border-color: #ffe0aa;                                  -fx-border-radius: 16;                                  -fx-border-width: 1;                                  -fx-effect: dropshadow(three-pass-box, rgba(240,170,79,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="20" left="22" right="22" top="20" />
                        </padding>
                        <Label style="-fx-text-fill: #d98928; -fx-font-size: 12px; -fx-font-weight: bold;" text="⚠️  Pending Approvals" />
                        <Label fx:id="pendingApprovalsLabel" style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;" text="—" />
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Medical approvals" />
                    </VBox>

                </FlowPane>

                <VBox spacing="14" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-border-color: #d7e7f8;                              -fx-border-radius: 16;                              -fx-border-width: 1;                              -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets bottom="22" left="24" right="24" top="22" />
                    </padding>

                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;" text="Quick Actions" />

                    <Separator style="-fx-background-color: #e7eef7;" />

                    <FlowPane hgap="12" vgap="12">
                        <Button onAction="#openMarkAttendance" prefHeight="42" prefWidth="190" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="✅  Mark Attendance" />

                        <Button onAction="#openAttendance" prefHeight="42" prefWidth="190" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="📋  View Attendance" />

                        <Button onAction="#openAdvancedAttendanceView" prefHeight="42" prefWidth="220" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                       -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="📊  Advanced Attendance View" />

                        <Button onAction="#openAllAttendance" prefHeight="42" prefWidth="220" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="All Attendance Table" />

                        <Button onAction="#openAddMedical" prefHeight="42" prefWidth="190" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="🏥  Add Medical" />

                        <Button onAction="#openMedical" prefHeight="42" prefWidth="190" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 13px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 10;                                        -fx-cursor: hand;" text="✔️  Approve Medical" />
                    </FlowPane>
                </VBox>

                <VBox spacing="14" style="-fx-background-color: white;                              -fx-background-radius: 16;                              -fx-border-color: #d7e7f8;                              -fx-border-radius: 16;                              -fx-border-width: 1;                              -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets bottom="22" left="24" right="24" top="22" />
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;" text="📊  Attendance Overview (Batch)" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#openAttendance" style="-fx-background-color: transparent;                                        -fx-text-fill: #4c8fce;                                        -fx-font-size: 12px;                                        -fx-font-weight: bold;                                        -fx-cursor: hand;" text="Full Report →" />
                    </HBox>

                    <Separator style="-fx-background-color: #e7eef7;" />

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="Batch" />

                        <TextField fx:id="batchEligibilityField" prefWidth="140" promptText="e.g. 2023" style="-fx-background-color: #ffffff;                                           -fx-text-fill: #1a3a52;                                           -fx-prompt-text-fill: #a8b8ca;                                           -fx-border-color: #d4e4f7;                                           -fx-border-radius: 8;                                           -fx-background-radius: 8;" />

                        <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="View" />

                        <ComboBox fx:id="viewTypeEligibilityCombo" prefWidth="150" style="-fx-background-color: #ffffff;                                          -fx-border-color: #d4e4f7;                                          -fx-border-radius: 8;                                          -fx-background-radius: 8;" />

                        <Button onAction="#refreshAttendanceEligibilityReport" prefHeight="34" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                        -fx-text-fill: white;                                        -fx-font-size: 12px;                                        -fx-font-weight: bold;                                        -fx-background-radius: 8;                                        -fx-cursor: hand;" text="Refresh" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="24">
                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-text-fill: #4cba52; -fx-font-size: 14px;" text="●" />
                            <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="Above 80%" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-text-fill: #f2c94c; -fx-font-size: 14px;" text="●" />
                            <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="Exactly 80%" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-text-fill: #e85d5d; -fx-font-size: 14px;" text="●" />
                            <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="Below 80%" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="6">
                            <Label style="-fx-font-size: 12px;" text="🏥" />
                            <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="With Medical" />
                        </HBox>
                    </HBox>

                    <VBox fx:id="attendanceSummaryContainer" spacing="8" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #fbfdff; -fx-border-color: #dfeaf6; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="9" left="28" right="28" top="9" />
            </padding>

            <Circle radius="4" style="-fx-fill: #4cba52;" />

            <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="System Online  •  Faculty of Technology Management System  •  v1.0" />

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="statusBarTime" style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="13 March 2026" />
        </HBox>
    </bottom>

</BorderPane>
