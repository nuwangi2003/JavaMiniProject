<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.attendance.AdvancedAttendanceViewController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: #f8fbff;">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 0 0 1 0;"
              spacing="12">

            <padding><Insets left="28" right="28"/></padding>

            <Label text="📊"
                   style="-fx-font-size: 24px;"/>

            <VBox spacing="2">
                <Label text="Attendance View"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="Individual AND Batch Analysis"
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusLabel"
                   text="Ready"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px; -fx-font-weight: bold;"/>

            <Button text="← Dashboard"
                    onAction="#backToDashboard"
                    style="-fx-background-color: #e8eef5;
                           -fx-text-fill: #5b9fd9;
                           -fx-border-color: #d4e4f7;
                           -fx-background-radius: 8;
                           -fx-border-radius: 8;
                           -fx-font-weight: bold;
                           -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="20">
            <padding><Insets top="30" left="30" right="30" bottom="30"/></padding>

            <!-- CONTROL PANEL -->
            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-border-color: #d4e4f7;
                         -fx-border-radius: 12;
                         -fx-padding: 20;">

                <Label text="Query Parameters"
                       style="-fx-text-fill: #1a3a52;
                              -fx-font-size: 14px;
                              -fx-font-weight: bold;"/>

                <HBox spacing="16">

                    <!-- Mode -->
                    <VBox spacing="6">
                        <Label text="Mode"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        <ComboBox fx:id="modeComboBox" prefWidth="150"/>
                    </VBox>

                    <!-- View Type -->
                    <VBox spacing="6">
                        <Label text="View Type"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        <ComboBox fx:id="viewTypeComboBox" prefWidth="150"/>
                    </VBox>

                    <!-- Target -->
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="targetLabel"
                               text="Student ID"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        <TextField fx:id="targetField"
                                   promptText="Enter value"
                                   HBox.hgrow="ALWAYS"/>
                    </VBox>

                    <!-- Buttons -->
                    <VBox spacing="6">
                        <Label text="Action"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        <HBox spacing="10">
                            <Button text="Load Details"
                                    onAction="#loadDetails"
                                    style="-fx-background-color: #e8eef5;
                                           -fx-text-fill: #5b9fd9;
                                           -fx-font-weight: bold;"/>

                            <Button text="Load Summary"
                                    onAction="#loadSummary"
                                    style="-fx-background-color: #5b9fd9;
                                           -fx-text-fill: white;
                                           -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>

                </HBox>
            </VBox>

            <!-- OUTPUT SECTION -->
            <HBox spacing="20" VBox.vgrow="ALWAYS">

                <!-- DETAILS -->
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-border-color: #d4e4f7;
                             -fx-border-radius: 12;
                             -fx-padding: 15;">

                    <Label text="Details"
                           style="-fx-text-fill: #1a3a52;
                                  -fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>

                    <TextArea fx:id="detailsArea"
                              VBox.vgrow="ALWAYS"
                              wrapText="true"
                              style="-fx-control-inner-background: #f5f9ff;
                                     -fx-text-fill: #1a3a52;"/>
                </VBox>

                <!-- SUMMARY -->
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 12;
                             -fx-border-color: #d4e4f7;
                             -fx-border-radius: 12;
                             -fx-padding: 15;">

                    <Label text="Summary"
                           style="-fx-text-fill: #1a3a52;
                                  -fx-font-size: 14px;
                                  -fx-font-weight: bold;"/>

                    <TextArea fx:id="summaryArea"
                              VBox.vgrow="ALWAYS"
                              wrapText="true"
                              style="-fx-control-inner-background: #f5f9ff;
                                     -fx-text-fill: #1a3a52;"/>
                </VBox>

            </HBox>
        </VBox>
    </center>

</BorderPane>