<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.ca.CAManagementController"
            prefWidth="1100" prefHeight="760"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: #ffffff;">
                <padding><Insets left="28" right="28"/></padding>
                <Label text="📝" style="-fx-font-size: 24px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="CA Management"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label text="Lecturer Panel"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="8">
                <padding><Insets left="16" right="24"/></padding>
                <Button text="Back Dashboard" onAction="#backToDashboard"
                        style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;
                               -fx-background-radius: 8; -fx-border-color: #d4e4f7;
                               -fx-border-radius: 8; -fx-border-width: 1;
                               -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-background-color: #f8fbff;">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                <VBox spacing="4">
                    <Label text="Continuous Assessment Management"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="Upload, update, view, and check CA eligibility records."
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                </VBox>

                <!-- Upload -->
                <VBox spacing="14"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                             -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Upload CA Marks"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                    <HBox spacing="10">
                        <TextField fx:id="uploadStudentIdField" promptText="student_id" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="uploadAssessmentTypeIdField" promptText="assessment_type_id" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="uploadMarksField" promptText="marks (0-100)" HBox.hgrow="ALWAYS"/>
                        <Button text="Upload" onAction="#uploadCAMarks"
                                style="-fx-background-color: #5b9fd9; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8;"/>
                    </HBox>
                </VBox>

                <!-- Update -->
                <VBox spacing="14"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                             -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <Label text="Update CA Marks"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                    <HBox spacing="10">
                        <TextField fx:id="updateMarkIdField" promptText="mark_id" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="updateMarksField" promptText="new marks" HBox.hgrow="ALWAYS"/>
                        <Button text="Update" onAction="#updateCAMarks"
                                style="-fx-background-color: #4cba52; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8;"/>
                    </HBox>
                </VBox>

                <!-- Student and Batch Marks -->
                <HBox spacing="20">
                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                                 -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="Get Student CA Marks"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <TextField fx:id="studentMarksStudentIdField" promptText="student_id" HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="studentMarksCourseIdField" promptText="course_id (optional)" HBox.hgrow="ALWAYS"/>
                            <Button text="Load" onAction="#getStudentCAMarks"
                                    style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;
                                           -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                                 -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="Get Batch CA Marks"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <TextField fx:id="batchMarksBatchField" promptText="batch" HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="batchMarksCourseIdField" promptText="course_id (optional)" HBox.hgrow="ALWAYS"/>
                            <Button text="Load" onAction="#getBatchCAMarks"
                                    style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;
                                           -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Eligibility -->
                <HBox spacing="20">
                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                                 -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="Check CA Eligibility"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <TextField fx:id="studentEligibilityStudentIdField" promptText="student_id" HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="studentEligibilityCourseIdField" promptText="course_id" HBox.hgrow="ALWAYS"/>
                            <Button text="Check" onAction="#checkCAEligibility"
                                    style="-fx-background-color: #f0a35a; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                                 -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="Batch CA Eligibility Report"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <TextField fx:id="batchEligibilityBatchField" promptText="batch" HBox.hgrow="ALWAYS"/>
                            <TextField fx:id="batchEligibilityCourseIdField" promptText="course_id" HBox.hgrow="ALWAYS"/>
                            <Button text="Load" onAction="#getBatchCAEligibilityReport"
                                    style="-fx-background-color: #8e5fd2; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Output -->
                <VBox spacing="12"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                             -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                    <Label text="Output"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #f5f9ff;
                                 -fx-background-radius: 8;
                                 -fx-border-color: #e8eef5;
                                 -fx-border-radius: 8;
                                 -fx-padding: 10 12 10 12;">
                        <Label fx:id="statusLabel" text=""
                               style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>

                    <TextArea fx:id="outputArea" prefHeight="240" wrapText="true"
                              style="-fx-control-inner-background: #f5f9ff;
                                     -fx-background-color: #f5f9ff;
                                     -fx-border-color: #d4e4f7;
                                     -fx-border-radius: 8;
                                     -fx-background-radius: 8;
                                     -fx-text-fill: #1a3a52;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>