<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.tech_officer.TechOfficerProfileController"
            prefWidth="1000" prefHeight="720"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: #ffffff;">
                <padding>
                    <Insets left="28" right="28"/>
                </padding>
                <Label text="🎓" style="-fx-font-size: 28px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="8">
                <padding>
                    <Insets left="16" right="16"/>
                </padding>
                <Label text="👤" style="-fx-font-size: 16px;"/>
                <Label text="My Profile"
                       style="-fx-text-fill: #8e5fd2; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #e8eef5;"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="16" right="24"/>
                </padding>
                <Button text="← Back" onAction="#goBack"
                        style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9; -fx-font-size: 12px;
                               -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: 600;
                               -fx-border-color: #d4e4f7; -fx-border-radius: 6; -fx-border-width: 1;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="28" style="-fx-background-color: #f8fbff;">
                <padding>
                    <Insets top="30" bottom="30" left="36" right="36"/>
                </padding>

                <VBox spacing="4">
                    <Label text="Technical Officer Profile"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                    <Label text="View your information and update your username, email, contact number, password, department, and profile picture."
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                </VBox>

                <HBox spacing="18"
                      alignment="CENTER_LEFT"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                             -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding>
                        <Insets top="24" bottom="24" left="24" right="24"/>
                    </padding>

                    <StackPane>
                        <Circle radius="34"
                                style="-fx-fill: #8e5fd2;"/>
                        <ImageView fx:id="profileImage"
                                   fitWidth="68" fitHeight="68"
                                   preserveRatio="false"
                                   visible="false"/>
                        <Label fx:id="profileInitial"
                               text="T"
                               style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    </StackPane>

                    <VBox spacing="4">
                        <Label fx:id="usernameLabel"
                               text="Technical Officer"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Label fx:id="subtitleLabel"
                               text="Technical Officer"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <VBox spacing="18"
                      style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                             -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding>
                        <Insets top="24" bottom="24" left="24" right="24"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Personal Information"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </HBox>

                    <Separator style="-fx-background-color: #e8eef5;"/>

                    <GridPane hgap="18" vgap="18">
                        <VBox spacing="7" GridPane.rowIndex="0" GridPane.columnIndex="0">
                            <Label text="User ID"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="userIdField"
                                       editable="false"
                                       style="-fx-control-inner-background: #f5f9ff; -fx-text-fill: #7f93a8;
                                              -fx-background-color: #f5f9ff; -fx-background-radius: 8;
                                              -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <Label text="Username"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="usernameTextField"
                                       promptText="Your username"
                                       style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                              -fx-prompt-text-fill: #a8b8ca;
                                              -fx-background-color: #ffffff; -fx-background-radius: 8;
                                              -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="1" GridPane.columnIndex="0">
                            <Label text="Role"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="roleField"
                                       editable="false"
                                       style="-fx-control-inner-background: #f5f9ff; -fx-text-fill: #7f93a8;
                                              -fx-background-color: #f5f9ff; -fx-background-radius: 8;
                                              -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <Label text="Department ID"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="departmentIdField"
                                       promptText="Department code"
                                       style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                              -fx-prompt-text-fill: #a8b8ca;
                                              -fx-background-color: #ffffff; -fx-background-radius: 8;
                                              -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="2" GridPane.columnIndex="0">
                            <Label text="Email"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="emailField"
                                       promptText="Enter your email"
                                       style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                              -fx-prompt-text-fill: #a8b8ca;
                                              -fx-background-color: #ffffff; -fx-background-radius: 8;
                                              -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <Label text="Contact Number"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <TextField fx:id="contactNumberField"
                                       promptText="Enter your contact number"
                                       style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                              -fx-prompt-text-fill: #a8b8ca;
                                              -fx-background-color: #ffffff; -fx-background-radius: 8;
                                              -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2">
                            <Label text="Profile Picture"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <TextField fx:id="profilePictureField"
                                           promptText="Choose image file path"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                                  -fx-prompt-text-fill: #a8b8ca;
                                                  -fx-background-color: #ffffff; -fx-background-radius: 8;
                                                  -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                                <Button text="Browse" onAction="#browseProfilePicture"
                                        style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;
                                               -fx-font-size: 12px; -fx-font-weight: 600;
                                               -fx-background-radius: 8; -fx-cursor: hand;
                                               -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-border-width: 1;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="4" GridPane.columnIndex="0">
                            <Label text="New Password"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField"
                                           promptText="Enter new password"
                                           style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                                  -fx-prompt-text-fill: #a8b8ca;
                                                  -fx-background-color: #ffffff; -fx-background-radius: 8;
                                                  -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox spacing="7" GridPane.rowIndex="4" GridPane.columnIndex="1">
                            <Label text="Confirm Password"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField"
                                           promptText="Re-enter new password"
                                           style="-fx-control-inner-background: #ffffff; -fx-text-fill: #1a3a52;
                                                  -fx-prompt-text-fill: #a8b8ca;
                                                  -fx-background-color: #ffffff; -fx-background-radius: 8;
                                                  -fx-border-color: #d4e4f7; -fx-border-radius: 8; -fx-font-size: 13px;"/>
                        </VBox>
                    </GridPane>

                    <Label fx:id="statusLabel"
                           text=""
                           visible="false"
                           managed="false"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                    <HBox alignment="CENTER_RIGHT" spacing="14">
                        <Button text="Save Changes"
                                onAction="#saveProfile"
                                prefHeight="42" prefWidth="160"
                                style="-fx-background-color: #4cba52;
                                       -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="8" bottom="8" left="28" right="28"/>
            </padding>
            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Technical Officer Profile"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>