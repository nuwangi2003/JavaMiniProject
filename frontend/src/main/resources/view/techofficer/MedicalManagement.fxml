<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.medical.MedicalManagementController"
            prefWidth="980" prefHeight="700"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: #ffffff;">
                <padding><Insets left="28" right="28"/></padding>
                <Label text="🩺" style="-fx-font-size: 24px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="Medical Management"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 17px; -fx-font-weight: bold;"/>
                    <Label text="Technical Officer Panel"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="8">
                <padding><Insets left="16" right="24"/></padding>
                <Button text="Back Dashboard" onAction="#backToDashboard"
                        style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;
                               -fx-background-radius: 8; -fx-border-color: #d4e4f7;
                               -fx-border-radius: 8; -fx-border-width: 1;
                               -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-background-color: #f8fbff;">
            <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>

            <VBox spacing="4">
                <Label text="Medical Records Review"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Label text="Load, review, approve, or reject submitted medical records."
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Filter Card -->
            <VBox spacing="16"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                         -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Filter Records"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="6">
                        <Label text="Batch"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <TextField fx:id="batchField" promptText="e.g. 2023" prefWidth="160"
                                   style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52;
                                          -fx-prompt-text-fill: #a8b8ca;
                                          -fx-border-color: #d4e4f7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-border-width: 1;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Status"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="statusFilterCombo" prefWidth="160"
                                  style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52;
                                         -fx-border-color: #d4e4f7; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-border-width: 1;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="Load Records" onAction="#loadBatchRecords"
                            style="-fx-background-color: #5b9fd9; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Records Card -->
            <VBox spacing="14"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                         -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Medical Records"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                <TextArea fx:id="recordsTextArea" prefHeight="380" wrapText="true"
                          style="-fx-control-inner-background: #f5f9ff;
                                 -fx-background-color: #f5f9ff;
                                 -fx-border-color: #d4e4f7;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;
                                 -fx-text-fill: #1a3a52;"/>
            </VBox>

            <!-- Action Card -->
            <VBox spacing="16"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 14;
                         -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Approval Actions"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <VBox spacing="6">
                        <Label text="Medical ID"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <TextField fx:id="medicalIdField" prefWidth="140" promptText="id"
                                   style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52;
                                          -fx-prompt-text-fill: #a8b8ca;
                                          -fx-border-color: #d4e4f7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-border-width: 1;"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="Approve" onAction="#approveSelected"
                            style="-fx-background-color: #4cba52; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button text="Reject" onAction="#rejectSelected"
                            style="-fx-background-color: #e85d5d; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: #f5f9ff;
                             -fx-background-radius: 8;
                             -fx-border-color: #e8eef5;
                             -fx-border-radius: 8;
                             -fx-padding: 10 12 10 12;">
                    <Label fx:id="statusLabel" text=""
                           style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>