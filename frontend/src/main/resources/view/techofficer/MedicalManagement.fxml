<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700" prefWidth="980" style="-fx-background-color: #f8fbff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.controller.medical.MedicalManagementController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" prefHeight="64" spacing="12" style="-fx-background-color: #ffffff;">
                <padding><Insets left="28" right="28" /></padding>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 17px; -fx-font-weight: bold;" text="Medical Management" />
                    <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;" text="Technical Officer Panel" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="8">
                <padding><Insets left="16" right="24" /></padding>
                <Button onAction="#backToDashboard" style="-fx-background-color: #e8eef5; -fx-text-fill: #5b9fd9;                                -fx-background-radius: 8; -fx-border-color: #d4e4f7;                                -fx-border-radius: 8; -fx-border-width: 1;                                -fx-font-weight: bold; -fx-cursor: hand;" text="Back Dashboard" />
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-background-color: #f8fbff;">
            <padding><Insets bottom="28" left="28" right="28" top="28" /></padding>

            <VBox spacing="4">
                <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;" text="Medical Records Review" />
                <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;" text="Load, review, approve, or reject submitted medical records." />
            </VBox>

            <!-- Filter Card -->
            <VBox spacing="16" style="-fx-background-color: #ffffff; -fx-background-radius: 14;                          -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;" text="Filter Records" />

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;" text="Batch" />
                        <TextField fx:id="batchField" prefWidth="160" promptText="e.g. 2023" style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52;                                           -fx-prompt-text-fill: #a8b8ca;                                           -fx-border-color: #d4e4f7; -fx-border-radius: 8;                                           -fx-background-radius: 8; -fx-border-width: 1;" />
                    </VBox>

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;" text="Status" />
                        <ComboBox fx:id="statusFilterCombo" prefWidth="160" style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52;                                          -fx-border-color: #d4e4f7; -fx-border-radius: 8;                                          -fx-background-radius: 8; -fx-border-width: 1;" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <Button onAction="#loadBatchRecords" style="-fx-background-color: #5b9fd9; -fx-text-fill: white;                                    -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Load Records" />
                </HBox>
            </VBox>

            <!-- Records + Actions -->
            <HBox spacing="20">
                <VBox spacing="14" style="-fx-background-color: #ffffff; -fx-background-radius: 14;                              -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;" text="Medical Records" />

                    <TableView fx:id="recordsTable" prefHeight="430" style="-fx-background-color: #f5f9ff;                                       -fx-border-color: #d4e4f7;                                       -fx-border-radius: 8;                                       -fx-background-radius: 8;">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="60" text="ID" />
                            <TableColumn fx:id="studentColumn" prefWidth="120" text="Student" />
                            <TableColumn fx:id="courseColumn" prefWidth="100" text="Course" />
                            <TableColumn fx:id="examTypeColumn" prefWidth="90" text="Exam" />
                            <TableColumn fx:id="dateColumn" prefWidth="110" text="Date" />
                            <TableColumn fx:id="copyColumn" prefWidth="220" text="Certificate / Note" />
                            <TableColumn fx:id="statusColumn" prefWidth="100" text="Status" />
                        </columns>
                    </TableView>
                </VBox>

                <VBox prefWidth="240" spacing="16" style="-fx-background-color: #ffffff; -fx-background-radius: 14;                              -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1;">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;" text="Approval Actions" />

                    <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;" text="Select a row from the table or enter a medical ID manually." wrapText="true" />

                    <VBox spacing="6">
                        <Label style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;" text="Medical ID" />
                        <TextField fx:id="medicalIdField" prefWidth="180" promptText="id" style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a52;                                           -fx-prompt-text-fill: #a8b8ca;                                           -fx-border-color: #d4e4f7; -fx-border-radius: 8;                                           -fx-background-radius: 8; -fx-border-width: 1;" />
                    </VBox>

                    <Button maxWidth="Infinity" onAction="#approveSelected" style="-fx-background-color: #4cba52; -fx-text-fill: white;                                    -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Approve" />

                    <Button maxWidth="Infinity" onAction="#rejectSelected" style="-fx-background-color: #e85d5d; -fx-text-fill: white;                                    -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Reject" />

                    <Region VBox.vgrow="ALWAYS" />

                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f5f9ff;                                  -fx-background-radius: 8;                                  -fx-border-color: #e8eef5;                                  -fx-border-radius: 8;                                  -fx-padding: 10 12 10 12;">
                        <Label fx:id="statusLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" text="" wrapText="true" />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
