<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.medical.AddMedicalController"
            prefWidth="940" prefHeight="700"
            style="-fx-background-color: #f8fbff;">

    <!-- TOP NAV BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="68" spacing="0"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 0 0 1 0;">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="14" prefHeight="68">
                <padding><Insets left="28" right="32"/></padding>
                <StackPane>
                    <Circle radius="20"
                            style="-fx-fill: linear-gradient(to bottom right, #5b9fd9, #4a8fcb);"/>
                    <Label text="🎓" style="-fx-font-size: 18px;"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                </VBox>
            </HBox>

            <Region prefWidth="1" prefHeight="36" style="-fx-background-color: #e8eef5;"/>

            <!-- Page Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="🩺" style="-fx-font-size: 16px;"/>
                <Label text="Add Medical Record"
                       style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;
                              -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Officer Info -->
            <HBox alignment="CENTER" spacing="12">
                <padding><Insets left="20" right="12"/></padding>
                <StackPane>
                    <Circle radius="20"
                            style="-fx-fill: linear-gradient(to bottom right, #4cba52, #39a940);"/>
                    <Label text="T"
                           style="-fx-text-fill: white; -fx-font-weight: bold;
                                  -fx-font-size: 14px; -fx-font-family: 'Segoe UI';"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label fx:id="officerNameLabel" text="Tech Officer"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 13px;
                                  -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Technical Officer"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                </VBox>
            </HBox>

            <!-- Back Button -->
            <HBox alignment="CENTER">
                <padding><Insets left="12" right="24"/></padding>
                <Button text="← Back" onAction="#backToDashboard"
                        prefHeight="36" prefWidth="100"
                        style="-fx-background-color: #e8eef5;
                               -fx-text-fill: #5b9fd9;
                               -fx-font-size: 12px; -fx-font-family: 'Segoe UI';
                               -fx-border-color: #d4e4f7;
                               -fx-border-radius: 8; -fx-border-width: 1;
                               -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: 600;"/>
            </HBox>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent; -fx-background-color: transparent;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

            <VBox spacing="0" style="-fx-background-color: #f8fbff;">
                <padding><Insets top="36" bottom="40" left="60" right="60"/></padding>

                <!-- Page Heading -->
                <HBox alignment="CENTER_LEFT" spacing="14">
                    <padding><Insets bottom="28"/></padding>
                    <StackPane>
                        <Circle radius="22"
                                style="-fx-fill: #eef6ff;"/>
                        <Label text="🩺" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="4">
                        <Label text="Add Medical Record"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 26px;
                                      -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                        <Label text="Submit a student medical certificate for exam exemption review"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px; -fx-font-family: 'Segoe UI';"/>
                    </VBox>
                </HBox>

                <!-- Main Card -->
                <VBox spacing="0"
                      style="-fx-background-color: #ffffff;
                             -fx-background-radius: 16;
                             -fx-border-color: #d4e4f7;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian,rgba(91,159,217,0.10),20,0,0,4);">

                    <!-- Card Header -->
                    <HBox alignment="CENTER_LEFT" spacing="14"
                          style="-fx-background-color: #f5f9ff;
                                 -fx-background-radius: 16 16 0 0;
                                 -fx-border-color: transparent transparent #e8eef5 transparent;
                                 -fx-border-width: 0 0 1 0;">
                        <padding><Insets top="20" bottom="20" left="28" right="28"/></padding>
                        <StackPane>
                            <Circle radius="18" style="-fx-fill: #eef6ff;"/>
                            <Label text="📋" style="-fx-font-size: 16px;"/>
                        </StackPane>
                        <VBox spacing="3">
                            <Label text="Medical Submission Form"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 15px;
                                          -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <Label text="All required details must be completed"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Pending after submit"
                               style="-fx-text-fill: #f0a35a; -fx-font-size: 10px;
                                      -fx-font-family: 'Segoe UI';
                                      -fx-background-color: #fff6ee;
                                      -fx-background-radius: 14;
                                      -fx-padding: 5 12;"/>
                    </HBox>

                    <!-- Form Body -->
                    <VBox spacing="24">
                        <padding><Insets top="32" bottom="32" left="32" right="32"/></padding>

                        <!-- Row 1 -->
                        <HBox spacing="20">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label text="Student ID"
                                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;
                                                  -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                    <Label text="*" style="-fx-text-fill: #e85d5d; -fx-font-size: 12px;"/>
                                </HBox>
                                <TextField fx:id="studentIdField"
                                           promptText="e.g. 677"
                                           prefHeight="44"
                                           style="-fx-background-color: #ffffff;
                                                  -fx-text-fill: #1a3a52;
                                                  -fx-prompt-text-fill: #a8b8ca;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #d4e4f7;
                                                  -fx-border-radius: 10;
                                                  -fx-border-width: 1.4;
                                                  -fx-font-size: 13px;
                                                  -fx-font-family: 'Segoe UI';
                                                  -fx-padding: 0 14;"/>
                                <Label text="Numeric student registration number"
                                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                            </VBox>

                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label text="Course ID"
                                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;
                                                  -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                    <Label text="*" style="-fx-text-fill: #e85d5d; -fx-font-size: 12px;"/>
                                </HBox>
                                <TextField fx:id="courseIdField"
                                           promptText="e.g. ICT1203"
                                           prefHeight="44"
                                           style="-fx-background-color: #ffffff;
                                                  -fx-text-fill: #1a3a52;
                                                  -fx-prompt-text-fill: #a8b8ca;
                                                  -fx-background-radius: 10;
                                                  -fx-border-color: #d4e4f7;
                                                  -fx-border-radius: 10;
                                                  -fx-border-width: 1.4;
                                                  -fx-font-size: 13px;
                                                  -fx-font-family: 'Segoe UI';
                                                  -fx-padding: 0 14;"/>
                                <Label text="Module code from the timetable"
                                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                            </VBox>
                        </HBox>

                        <!-- Row 2 -->
                        <HBox spacing="20">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label text="Exam Type"
                                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;
                                                  -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                    <Label text="*" style="-fx-text-fill: #e85d5d; -fx-font-size: 12px;"/>
                                </HBox>
                                <ComboBox fx:id="examTypeCombo"
                                          maxWidth="Infinity"
                                          prefHeight="44"
                                          visibleRowCount="5"
                                          style="-fx-background-color: #ffffff;
                                                 -fx-background-radius: 10;
                                                 -fx-border-color: #d4e4f7;
                                                 -fx-border-radius: 10;
                                                 -fx-border-width: 1.4;
                                                 -fx-text-fill: #1a3a52;
                                                 -fx-font-size: 13px;
                                                 -fx-font-family: 'Segoe UI';
                                                 -fx-padding: 0 14;"/>
                                <Label text="Type of assessment session"
                                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                            </VBox>

                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <HBox spacing="4" alignment="CENTER_LEFT">
                                    <Label text="Date Submitted"
                                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;
                                                  -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                                    <Label text="*" style="-fx-text-fill: #e85d5d; -fx-font-size: 12px;"/>
                                </HBox>
                                <DatePicker fx:id="submittedDatePicker"
                                            maxWidth="Infinity"
                                            prefHeight="44"
                                            promptText="Select date"
                                            style="-fx-background-color: #ffffff;
                                                   -fx-background-radius: 10;
                                                   -fx-border-color: #d4e4f7;
                                                   -fx-border-radius: 10;
                                                   -fx-border-width: 1.4;
                                                   -fx-font-size: 13px;
                                                   -fx-font-family: 'Segoe UI';"/>
                                <Label text="Must match the exam session date"
                                       style="-fx-text-fill: #f0a35a; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                            </VBox>
                        </HBox>

                        <!-- Row 3 -->
                        <VBox spacing="8">
                            <Label text="Medical Certificate / Note"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 12px;
                                          -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
                            <TextField fx:id="medicalCopyField"
                                       promptText="File path or short description of document"
                                       prefHeight="44"
                                       style="-fx-background-color: #ffffff;
                                              -fx-text-fill: #1a3a52;
                                              -fx-prompt-text-fill: #a8b8ca;
                                              -fx-background-radius: 10;
                                              -fx-border-color: #d4e4f7;
                                              -fx-border-radius: 10;
                                              -fx-border-width: 1.4;
                                              -fx-font-size: 13px;
                                              -fx-font-family: 'Segoe UI';
                                              -fx-padding: 0 14;"/>
                            <Label text="Attach a scanned copy reference or enter a note"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
                        </VBox>

                        <HBox>
                            <Region prefHeight="1"
                                    style="-fx-background-color: #e8eef5;"
                                    HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <!-- Status -->
                        <HBox minHeight="24" alignment="CENTER_LEFT"
                              style="-fx-background-color: #f5f9ff;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #e8eef5;
                                     -fx-border-radius: 10;
                                     -fx-padding: 12 14;">
                            <Label fx:id="statusLabel" text=""
                                   wrapText="true"
                                   style="-fx-font-size: 13px; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Buttons -->
                        <HBox spacing="14" alignment="CENTER_RIGHT">
                            <Button text="Clear Form" onAction="#clearForm"
                                    prefHeight="44" prefWidth="140"
                                    style="-fx-background-color: #e8eef5;
                                           -fx-text-fill: #5b9fd9;
                                           -fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                           -fx-background-radius: 10;
                                           -fx-border-color: #d4e4f7;
                                           -fx-border-radius: 10;
                                           -fx-border-width: 1.4;
                                           -fx-cursor: hand;"/>

                            <Button text="🩺  Submit Medical" onAction="#submitMedical"
                                    prefHeight="44" prefWidth="190"
                                    style="-fx-background-color: #4cba52;
                                           -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-font-family: 'Segoe UI';
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;
                                           -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Info Strip -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <padding><Insets top="18"/></padding>
                    <Label text="ℹ" style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px;"/>
                    <Label text="Submitted records are set to Pending status and reviewed before approval."
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-family: 'Segoe UI';"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- STATUS BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" prefHeight="36"
              style="-fx-background-color: #ffffff;
                     -fx-border-color: #e8eef5;
                     -fx-border-width: 1 0 0 0;">
            <padding><Insets left="24" right="24"/></padding>
            <Circle radius="5" style="-fx-fill: #4cba52;"/>
            <Label text="System Online"
                   style="-fx-text-fill: #4cba52; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
            <Label text="•" style="-fx-text-fill: #d4e4f7; -fx-font-size: 10px;"/>
            <Label text="Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusBarTime" text=""
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-family: 'Segoe UI';"/>
        </HBox>
    </bottom>

</BorderPane>