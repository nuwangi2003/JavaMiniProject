<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760" prefWidth="1240" style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.controller.attendance.AllAttendanceController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);                      -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">
            <HBox alignment="CENTER_LEFT" prefHeight="70" prefWidth="266.0" spacing="12">
                <padding><Insets left="26" right="26" /></padding>
                <VBox spacing="2">
                    <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="All Attendance" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.82); -fx-font-size: 10px;" text="Technical Officer Panel" />
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="10">
                <padding><Insets left="10" right="22" /></padding>
                <Button onAction="#backToDashboard" style="-fx-background-color: rgba(255,255,255,0.18);                                -fx-text-fill: white;                                -fx-font-size: 12px;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-border-color: rgba(255,255,255,0.22);                                -fx-border-radius: 8;                                -fx-border-width: 1;                                -fx-cursor: hand;" text="Back Dashboard" />
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="22">
            <padding><Insets bottom="28" left="32" right="32" top="28" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="18" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-border-color: #d7e7f8;                          -fx-border-radius: 16;                          -fx-border-width: 1;">
                <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>

                <VBox spacing="5">
                    <Label style="-fx-text-fill: #1a3a52; -fx-font-size: 24px; -fx-font-weight: bold;" text="All Attendance Records" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="totalRecordsLabel" style="-fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold;" text="0 records" />
            </HBox>

            <VBox spacing="16" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-border-color: #d7e7f8;                          -fx-border-radius: 16;                          -fx-border-width: 1;                          -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.12), 14, 0, 0, 4);">
                <padding><Insets bottom="22" left="24" right="24" top="22" /></padding>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;" text="View" />
                    <ComboBox fx:id="viewTypeComboBox" prefWidth="160" style="-fx-background-color: #ffffff;                                      -fx-border-color: #d4e4f7;                                      -fx-border-radius: 8;                                      -fx-background-radius: 8;" />
                    <Button onAction="#loadAllAttendance" style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);                                    -fx-text-fill: white;                                    -fx-font-size: 12px;                                    -fx-font-weight: bold;                                    -fx-background-radius: 8;                                    -fx-cursor: hand;" text="Refresh" />
                </HBox>

                <TableView fx:id="attendanceTable" prefHeight="520" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #d7e7f8;">
                    <columns>
                        <TableColumn fx:id="attendanceIdColumn" prefWidth="88" text="Attendance ID" />
                        <TableColumn fx:id="regNoColumn" prefWidth="118" text="Reg No" />
                        <TableColumn fx:id="studentNameColumn" prefWidth="160" text="Student Name" />
                        <TableColumn fx:id="departmentColumn" prefWidth="170" text="Department" />
                        <TableColumn fx:id="batchColumn" prefWidth="90" text="Batch" />
                        <TableColumn fx:id="courseIdColumn" prefWidth="100" text="Course" />
                        <TableColumn fx:id="sessionDateColumn" prefWidth="130" text="Session Date" />
                        <TableColumn fx:id="sessionTypeColumn" prefWidth="100" text="Type" />
                        <TableColumn fx:id="statusColumn" prefWidth="90" text="Status" />
                        <TableColumn fx:id="hoursAttendedColumn" prefWidth="100" text="Hours" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f5f9ff;                              -fx-background-radius: 8;                              -fx-border-color: #e8eef5;                              -fx-border-radius: 8;                              -fx-padding: 10 12 10 12;">
                    <Label fx:id="statusLabel" style="-fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
