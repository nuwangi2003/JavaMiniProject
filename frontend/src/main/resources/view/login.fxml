<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend.controller.admin.LoginController"
      spacing="0" alignment="TOP_CENTER"
      style="-fx-background-color: #f8fbff;">

    <!-- Include the existing title bar -->
    <fx:include source="loginTitleBar.fxml" />

    <!-- Main login form -->
    <StackPane VBox.vgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="28">

            <VBox alignment="CENTER" prefHeight="320.0" prefWidth="480.0" spacing="18"
                  style="-fx-background-color: #fafbff; -fx-background-radius: 16; -fx-border-color: #d4e4f7; -fx-border-radius: 16; -fx-border-width: 1.5; -fx-effect: dropshadow(three-pass-box,rgba(91,159,217,0.15),16,0,0,6);">
                <padding>
                    <Insets top="44" bottom="44" left="44" right="44"/>
                </padding>

                <!-- Header -->
                <VBox alignment="CENTER" spacing="6">
                    <Label text="Welcome Back"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Sign in to your account to continue"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Username -->
                <VBox spacing="7">
                    <Label text="Username"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField" alignment="CENTER_LEFT" prefHeight="44"
                               promptText="Enter your username"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d4e4f7; -fx-background-color: #ffffff; -fx-text-fill: #1a3a52; -fx-prompt-text-fill: #a8b8ca; -fx-border-width: 1; -fx-font-size: 13px; -fx-padding: 10 14 10 14;">
                        <font>
                            <Font size="13.0"/>
                        </font>
                    </TextField>
                </VBox>

                <!-- Password -->
                <VBox spacing="7">
                    <Label text="Password"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField" alignment="CENTER_LEFT" prefHeight="44"
                                   promptText="Enter your password"
                                   style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d4e4f7; -fx-background-color: #ffffff; -fx-text-fill: #1a3a52; -fx-prompt-text-fill: #a8b8ca; -fx-border-width: 1; -fx-font-size: 13px; -fx-padding: 10 14 10 14;">
                        <font>
                            <Font size="13.0"/>
                        </font>
                    </PasswordField>
                </VBox>

                <!-- Login button -->
                <Button onAction="#login" prefHeight="44" prefWidth="200" text="Sign In"
                        style="-fx-background-color: #5b9fd9;
                               -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>

                <!-- Status label -->
                <Label fx:id="statusLabel" textFill="#e85d5d" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

            </VBox>

        </VBox>
    </StackPane>

</VBox>