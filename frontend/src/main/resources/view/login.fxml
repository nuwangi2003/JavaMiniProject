<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.frontend.controller.admin.LoginController"
      spacing="0" alignment="TOP_CENTER"
      style="-fx-background-color: linear-gradient(to bottom right, #0f1b35, #0a1628);">

    <!-- Include the existing title bar -->
    <fx:include source="loginTitleBar.fxml" />

    <!-- Main login form -->
    <StackPane VBox.vgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="25">

            <VBox alignment="CENTER" prefHeight="300.0" prefWidth="470.0" spacing="15"
                  style="-fx-background-color: #1e293b; -fx-background-radius: 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20,0,0,10);">
                <padding>
                    <Insets top="40" bottom="40" left="40" right="40"/>
                </padding>

                <!-- Username -->
                <TextField fx:id="usernameField" alignment="CENTER" prefHeight="40" promptText="Username"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #3a4b63; -fx-background-color: #283447; -fx-text-fill: white;">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </TextField>

                <!-- Password -->
                <PasswordField fx:id="passwordField" alignment="CENTER" prefHeight="40" promptText="Password"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #3a4b63; -fx-background-color: #283447; -fx-text-fill: white;">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </PasswordField>

                <!-- Login button -->
                <Button onAction="#login" prefHeight="40" prefWidth="200" text="Login"
                        style="-fx-background-color: linear-gradient(to right, #28a745, #1e7e34);
                               -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <!-- Status label -->
                <Label fx:id="statusLabel" textFill="#ff4d4f" style="-fx-font-size: 12px;"/>

            </VBox>

        </VBox>
    </StackPane>

</VBox>
