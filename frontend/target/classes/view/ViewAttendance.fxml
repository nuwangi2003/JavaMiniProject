<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.attendance.ViewAttendanceController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #0f1b35;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #0a1628; -fx-border-color: #1e3c72; -fx-border-width: 0 0 2 0;">
            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64"
                  style="-fx-background-color: linear-gradient(to right, #1e3c72, #2a5298);">
                <padding><Insets left="24" right="24"/></padding>
                <Label text="📋" style="-fx-font-size: 24px;"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="Attendance Module" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label text="Technical Officer Panel" style="-fx-text-fill: #a0b8e0; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="8">
                <padding><Insets left="16" right="20"/></padding>
                <Label text="View Attendance" style="-fx-text-fill: #a0c4ff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="24" style="-fx-background-color: #0f1b35;">
            <padding><Insets top="30" bottom="30" left="38" right="38"/></padding>

            <VBox spacing="4">
                <Label text="View Attendance Record"
                       style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label text="Search and view attendance details by attendance ID."
                       style="-fx-text-fill: #6a90c8; -fx-font-size: 13px;"/>
            </VBox>

            <VBox spacing="18"
                  style="-fx-background-color: #162040; -fx-background-radius: 14;
                         -fx-border-color: #1e3c72; -fx-border-radius: 14; -fx-border-width: 1;">
                <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

                <HBox spacing="10">
                    <TextField fx:id="attendanceIdField" promptText="Enter attendance ID (e.g. 5)"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #0f1b35; -fx-text-fill: white; -fx-prompt-text-fill: #3a5a8a;
                                      -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1;"/>
                    <Button text="Search" onAction="#findAttendance"
                            style="-fx-background-color: linear-gradient(to right, #0a4a6e, #1565c0); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <GridPane hgap="20" vgap="10">
                    <Label text="Attendance ID" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="attendanceIdValue" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Student ID" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="studentIdValue" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Session ID" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="sessionIdValue" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Status" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="statusValue" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Hours Attended" style="-fx-text-fill: #a0c4ff; -fx-font-size: 12px; -fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="hoursValue" text="-" style="-fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                </GridPane>

                <Label fx:id="resultLabel" textFill="WHITE" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Back Dashboard" onAction="#backToDashboard"
                            style="-fx-background-color: #1e2d50; -fx-text-fill: #a0b8e0; -fx-background-radius: 8;
                                   -fx-border-color: #2a4a7f; -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>
                    <Button text="Go Update/Delete" onAction="#goUpdateDelete"
                            style="-fx-background-color: #1e3c72; -fx-text-fill: white; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
